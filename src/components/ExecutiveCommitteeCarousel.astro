---
import MemberCard from './MemberCard.astro';

interface Props {
  members: any[];
}

const { members } = Astro.props;
---

<div class="committee-carousel">
  <div class="carousel-container">
    <button class="carousel-control prev" id="prevBtn" aria-label="Previous">
      <i class="fas fa-chevron-left"></i>
    </button>
    
    <div class="carousel-wrapper">
      <div class="carousel-track" id="carouselTrack">
        {members.map(member => (
          <div class="carousel-item">
            <MemberCard 
              name={member.frontmatter.name}
              position={member.frontmatter.position}
              image={member.frontmatter.image}
            />
          </div>
        ))}
      </div>
    </div>
    
    <button class="carousel-control next" id="nextBtn" aria-label="Next">
      <i class="fas fa-chevron-right"></i>
    </button>
  </div>
  
  <div class="carousel-indicators" id="indicators"></div>
</div>

<style>
  .committee-carousel {
    width: 100%;
  }

  .carousel-container {
    display: flex;
    align-items: center;
    gap: 20px;
    position: relative;
  }

  .carousel-wrapper {
    flex: 1;
    overflow: hidden;
    border-radius: 8px;
  }

  .carousel-track {
    display: flex;
    gap: 24px;
    transition: transform 0.4s cubic-bezier(0.4, 0, 0.2, 1);
    padding: 12px;
  }

  .carousel-item {
    min-width: calc(33.333% - 16px);
    flex-shrink: 0;
  }

  @media (max-width: 992px) {
    .carousel-item {
      min-width: calc(50% - 12px);
    }
  }

  @media (max-width: 576px) {
    .carousel-item {
      min-width: 100%;
    }
  }

  .carousel-control {
    background: linear-gradient(135deg, #ffc107 0%, #ffb600 100%);
    border: none;
    width: 50px;
    height: 50px;
    border-radius: 50%;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    color: #1a1a2e;
    font-weight: 700;
    transition: all 0.3s ease;
    box-shadow: 0 4px 12px rgba(255, 193, 7, 0.3);
    z-index: 10;
    flex-shrink: 0;
  }

  .carousel-control:hover {
    transform: scale(1.1);
    box-shadow: 0 6px 16px rgba(255, 193, 7, 0.4);
  }

  .carousel-control:active {
    transform: scale(0.95);
  }

  .carousel-control i {
    font-size: 1.2rem;
  }

  .carousel-indicators {
    display: flex;
    justify-content: center;
    gap: 10px;
    margin-top: 24px;
    flex-wrap: wrap;
  }

  .indicator {
    width: 10px;
    height: 10px;
    border-radius: 50%;
    background: #ddd;
    border: 2px solid transparent;
    cursor: pointer;
    transition: all 0.3s ease;
  }

  .indicator.active {
    background: #ffc107;
    border-color: #1a1a2e;
    width: 30px;
    border-radius: 5px;
  }
</style>

<script>
  document.addEventListener('DOMContentLoaded', function() {
    const track = document.getElementById('carouselTrack');
    const prevBtn = document.getElementById('prevBtn');
    const nextBtn = document.getElementById('nextBtn');
    const indicatorsContainer = document.getElementById('indicators');
    
    if (!track || !prevBtn || !nextBtn) return;

    const items = track.querySelectorAll('.carousel-item');
    const itemCount = items.length;
    const itemsPerView = window.innerWidth > 992 ? 3 : window.innerWidth > 576 ? 2 : 1;
    const maxSlide = Math.max(0, itemCount - itemsPerView);
    
    let currentSlide = 0;

    // Create indicators
    const indicatorCount = Math.ceil(itemCount / itemsPerView);
    for (let i = 0; i < indicatorCount; i++) {
      const indicator = document.createElement('button');
      indicator.classList.add('indicator');
      if (i === 0) indicator.classList.add('active');
      indicator.addEventListener('click', () => goToSlide(i * itemsPerView));
      indicatorsContainer.appendChild(indicator);
    }

    const indicators = indicatorsContainer.querySelectorAll('.indicator');

    function updateCarousel() {
      const itemWidth = track.querySelector('.carousel-item').offsetWidth + 24; // 24px gap
      const offset = -(currentSlide * itemWidth);
      track.style.transform = `translateX(${offset}px)`;

      indicators.forEach((ind, index) => {
        ind.classList.toggle('active', 
          index === Math.floor(currentSlide / itemsPerView)
        );
      });
    }

    function goToSlide(index) {
      currentSlide = Math.max(0, Math.min(index, maxSlide));
      updateCarousel();
    }

    prevBtn.addEventListener('click', () => {
      goToSlide(currentSlide - itemsPerView);
    });

    nextBtn.addEventListener('click', () => {
      goToSlide(currentSlide + itemsPerView);
    });

    // Handle window resize
    window.addEventListener('resize', () => {
      currentSlide = 0;
      updateCarousel();
    });

    // Initial update
    updateCarousel();
  });
</script>
