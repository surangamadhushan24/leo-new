---
interface Props {
  members: any[];
}
const { members } = Astro.props;
---

<div class="committee-carousel">
  <div class="cc-container">
    <div class="cc-wrapper-outer">
      <button class="cc-nav cc-prev" id="committeePrevBtn" aria-label="Previous">❮</button>

      <div class="cc-wrapper" id="ccWrapper">
        <div class="cc-track" id="committeeCarouselTrack">
          {members && members.length > 0 ? (
            members.slice(0, 6).map((member, index) => (
              <div class={`cc-card card-${(index % 6) + 1}`}>
                <div class="cc-cover">
                  <div class="cc-photo">
                    <img
                      src={member.frontmatter.image || 'https://via.placeholder.com/400x400?text=' + encodeURIComponent(member.frontmatter.name)}
                      alt={member.frontmatter.name}
                    />
                  </div>
                  <span class="cc-badge">{member.frontmatter.position}</span>
                </div>
                <div class="cc-info">
                  <h3 class="cc-name">{member.frontmatter.name}</h3>
                  <p class="cc-position">{member.frontmatter.position}</p>
                  <div class="cc-footer">
                    <div class="cc-socials">
                      <a href="#" class="cc-social" title="Email">✉</a>
                      <a href="#" class="cc-social" title="LinkedIn">in</a>
                      <a href="#" class="cc-social" title="Twitter">𝕏</a>
                    </div>
                  </div>
                </div>
              </div>
            ))
          ) : (
            <p style="color:#666;padding:40px;">No committee members found.</p>
          )}
        </div>
      </div>

      <button class="cc-nav cc-next" id="committeeNextBtn" aria-label="Next">❯</button>
    </div>

    <div class="cc-dots" id="committeeDots"></div>
  </div>
</div>

<style>
  /* Transparent root — inherits parent section's background */
  .committee-carousel {
    background: transparent;
    padding: 0 20px 48px;
  }

  .cc-container {
    max-width: 1400px;
    margin: 0 auto;
  }

  .cc-wrapper-outer {
    position: relative;
    width: 100%;
  }

  .cc-wrapper {
    overflow: hidden;
    margin: 0 70px;
  }

  .cc-track {
    display: flex;
    gap: 28px;
    transition: transform 0.45s cubic-bezier(0.4, 0, 0.2, 1);
    padding: 80px 4px 32px;
  }

  /* ── Card ── */
  .cc-card {
    flex: 0 0 calc(25% - 21px);
    background: #ffffff;
    border-radius: 20px;
    overflow: visible;
    box-shadow: 0 4px 20px rgba(26, 26, 46, 0.09);
    border: 1px solid rgba(26, 26, 46, 0.06);
    transition: transform 0.35s cubic-bezier(0.4,0,0.2,1), box-shadow 0.35s;
    cursor: pointer;
    position: relative;
  }

  .cc-card:hover {
    transform: translateY(-12px);
    box-shadow: 0 20px 48px rgba(26, 26, 46, 0.13);
  }

  /* Card top strip — uses the club navy */
  .cc-cover {
    position: relative;
    height: 160px;
    border-radius: 20px 20px 0 0;
    background: linear-gradient(135deg, #1a1a2e 0%, #16213e 100%);
    overflow: visible;
  }

  /* Circular photo */
  .cc-photo {
    position: absolute;
    bottom: -64px;
    left: 50%;
    transform: translateX(-50%);
    width: 128px;
    height: 128px;
    border-radius: 50%;
    border: 5px solid #fff;
    background: #fff;
    overflow: hidden;
    box-shadow: 0 6px 24px rgba(0, 0, 0, 0.16);
    z-index: 10;
    transition: transform 0.3s ease, box-shadow 0.3s ease;
  }

  .cc-card:hover .cc-photo {
    transform: translateX(-50%) scale(1.06);
    box-shadow: 0 10px 32px rgba(0, 0, 0, 0.2);
  }

  .cc-photo img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  /* Gold badge */
  .cc-badge {
    position: absolute;
    top: 12px;
    right: 12px;
    background: linear-gradient(135deg, #ffc107, #e6a800);
    color: #1a1a2e;
    padding: 5px 12px;
    border-radius: 20px;
    font-size: 0.65rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    box-shadow: 0 3px 10px rgba(255, 193, 7, 0.4);
    white-space: nowrap;
    z-index: 11;
    transition: transform 0.25s ease;
  }

  .cc-card:hover .cc-badge { transform: scale(1.08); }

  /* Card body */
  .cc-info {
    padding: 82px 18px 20px;
    text-align: center;
    background: #ffffff;
    border-radius: 0 0 20px 20px;
  }

  .cc-name {
    font-size: 1.05rem;
    font-weight: 700;
    color: #1a1a2e;
    margin-bottom: 4px;
    line-height: 1.3;
  }

  .cc-position {
    font-size: 0.72rem;
    color: #e6a800;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.6px;
    margin-bottom: 12px;
  }

  .cc-footer {
    border-top: 1px solid #f0f0f0;
    padding-top: 10px;
    margin-top: 4px;
  }

  .cc-socials {
    display: flex;
    gap: 8px;
    justify-content: center;
    opacity: 0;
    transform: translateY(5px);
    transition: opacity 0.25s, transform 0.25s;
  }

  .cc-card:hover .cc-socials {
    opacity: 1;
    transform: translateY(0);
  }

  .cc-social {
    width: 34px;
    height: 34px;
    background: #f7f7f5;
    border: 1px solid #eee;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    text-decoration: none;
    color: #1a1a2e;
    font-weight: bold;
    font-size: 0.85rem;
    transition: all 0.22s ease;
  }

  .cc-social:hover {
    background: linear-gradient(135deg, #ffc107, #e6a800);
    border-color: transparent;
    transform: translateY(-2px);
    box-shadow: 0 4px 12px rgba(255,193,7,.35);
  }

  /* ── Nav buttons ── */
  .cc-nav {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    background: #ffffff;
    color: #1a1a2e;
    border: 2px solid #ffc107;
    width: 48px;
    height: 48px;
    border-radius: 50%;
    font-size: 1.3rem;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: all 0.22s ease;
    z-index: 20;
    box-shadow: 0 3px 12px rgba(0,0,0,.10);
  }

  .cc-nav:hover {
    background: linear-gradient(135deg, #ffc107, #e6a800);
    transform: translateY(-50%) scale(1.08);
    box-shadow: 0 6px 20px rgba(255,193,7,.35);
  }

  .cc-prev { left: 0; }
  .cc-next { right: 0; }

  /* ── Dots ── */
  .cc-dots {
    display: flex;
    justify-content: center;
    gap: 10px;
    padding-top: 8px;
    padding-bottom: 4px;
  }

  .cc-dot {
    width: 11px;
    height: 11px;
    border-radius: 50%;
    background: #ddd;
    cursor: pointer;
    transition: all 0.3s ease;
  }

  .cc-dot.active {
    background: #ffc107;
    width: 30px;
    border-radius: 6px;
  }

  .cc-dot:hover { background: #ffc107; }

  /* ── Responsive ── */
  @media (max-width: 1200px) {
    .cc-card { flex: 0 0 calc(33.333% - 19px); }
  }

  @media (max-width: 768px) {
    .cc-card   { flex: 0 0 calc(50% - 14px); }
    .cc-wrapper { margin: 0 52px; }
    .cc-photo  { width: 110px; height: 110px; bottom: -52px; }
    .cc-cover  { height: 140px; }
    .cc-info   { padding: 70px 14px 18px; }
    .cc-track  { padding: 65px 4px 28px; gap: 20px; }
  }

  @media (max-width: 480px) {
    .cc-card   { flex: 0 0 100%; }
    .cc-wrapper { margin: 0 44px; }
    .cc-photo  { width: 100px; height: 100px; bottom: -46px; }
    .cc-info   { padding: 60px 12px 16px; }
    .cc-track  { padding: 55px 4px 24px; gap: 16px; }
  }

  /* ── Entry animation ── */
  @keyframes fadeUp {
    from { opacity: 0; transform: translateY(20px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  .cc-card { opacity: 0; animation: fadeUp 0.5s ease forwards; }
  .card-1  { animation-delay: 0.08s; }
  .card-2  { animation-delay: 0.16s; }
  .card-3  { animation-delay: 0.24s; }
  .card-4  { animation-delay: 0.32s; }
  .card-5  { animation-delay: 0.40s; }
  .card-6  { animation-delay: 0.48s; }
</style>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const track  = document.getElementById('committeeCarouselTrack') as HTMLElement | null;
    const prev   = document.getElementById('committeePrevBtn')       as HTMLElement | null;
    const next   = document.getElementById('committeeNextBtn')       as HTMLElement | null;
    const dotsEl = document.getElementById('committeeDots')          as HTMLElement | null;
    const cards  = track?.querySelectorAll<HTMLElement>('.cc-card');

    if (!track || !prev || !next || !dotsEl || !cards || cards.length === 0) return;

    let idx = 0;
    const GAP = 28;

    const cpv = () => {
      const w = window.innerWidth;
      return w < 480 ? 1 : w < 768 ? 2 : w < 1200 ? 3 : 4;
    };

    let perView = cpv();

    const render = () => {
      const cw = cards[0].offsetWidth;
      track.style.transform = `translateX(${-(idx * (cw + GAP))}px)`;
      dotsEl.querySelectorAll<HTMLElement>('.cc-dot').forEach((d, i) =>
        d.classList.toggle('active', i === idx)
      );
    };

    const go = (i: number) => {
      idx = Math.max(0, Math.min(i, cards.length - perView));
      render();
    };

    const buildDots = () => {
      dotsEl.innerHTML = '';
      const n = Math.max(1, cards.length - perView + 1);
      for (let i = 0; i < n; i++) {
        const d = document.createElement('div');
        d.className = 'cc-dot' + (i === 0 ? ' active' : '');
        d.onclick = () => go(i);
        dotsEl.appendChild(d);
      }
    };

    prev.addEventListener('click', () => go(idx - 1));
    next.addEventListener('click', () => go(idx + 1));

    window.addEventListener('resize', () => {
      const nv = cpv();
      if (nv !== perView) { perView = nv; idx = 0; buildDots(); }
      render();
    });

    document.addEventListener('keydown', e => {
      if (e.key === 'ArrowLeft') go(idx - 1);
      if (e.key === 'ArrowRight') go(idx + 1);
    });

    buildDots();
    render();
  });
</script>