---
interface Props {
  members: any[];
}

const { members } = Astro.props;
---

<div class="committee-carousel">
  <div class="container">
    <div class="header">
      <div class="header-decorations">
        <div class="decoration-line decoration-gold"></div>
        <div class="decoration-line decoration-red"></div>
      </div>
      <h1>Executive Committee 2025/26</h1>
      <p>Meet the dedicated leaders guiding our organization towards excellence and community impact</p>
    </div>

    <div class="carousel-container">
      <button class="carousel-nav prev" id="committeePrevBtn" aria-label="Previous">❮</button>

      <div class="carousel-wrapper">
        <div class="carousel-track" id="committeeCarouselTrack">
          {members && members.length > 0 ? (
            members.slice(0, 6).map((member, index) => (
              <div class={`member-card card-${(index % 6) + 1}`}>
                <div class="member-cover">
                  <div class="member-photo-overlay">
                    <img src={member.frontmatter.image || 'https://via.placeholder.com/400x400?text=' + encodeURIComponent(member.frontmatter.name)} alt={member.frontmatter.name} />
                  </div>
                  <span class="position-badge">{member.frontmatter.position}</span>
                </div>
                <div class="member-info">
                  <h3 class="member-name">{member.frontmatter.name}</h3>
                  <p class="member-position">{member.frontmatter.position}</p>
                  <p class="member-bio">{member.frontmatter.bio || 'Dedicated leader contributing to our community'}</p>
                  <div class="member-footer">
                    {member.frontmatter.email && (
                      <a href={`mailto:${member.frontmatter.email}`} class="member-email">{member.frontmatter.email}</a>
                    )}
                    <div class="action-buttons">
                      <button class="view-profile-btn">View Profile</button>
                      <button class="msg-btn">Message</button>
                    </div>
                    <div class="social-icons">
                      <a href="#" class="social-icon" title="Email">✉</a>
                      <a href="#" class="social-icon" title="LinkedIn">in</a>
                      <a href="#" class="social-icon" title="Twitter">𝕏</a>
                    </div>
                  </div>
                </div>
              </div>
            ))
          ) : (
            <div class="empty-state">
              <p>No committee members found</p>
            </div>
          )}
        </div>
      </div>

      <button class="carousel-nav next" id="committeeNextBtn" aria-label="Next">❯</button>
    </div>

    <div class="carousel-dots" id="committeeDots"></div>
  </div>
</div>

<style>
  * {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
  }

  .committee-carousel {
    background: linear-gradient(135deg, #f5f7fa 0%, #c3cfe2 100%);
    padding: 40px 20px;
    min-height: 100vh;
  }

  .container {
    max-width: 1400px;
    margin: 0 auto;
  }

  .header {
    text-align: center;
    margin-bottom: 60px;
  }

  .header-decorations {
    display: flex;
    justify-content: center;
    gap: 12px;
    margin-bottom: 20px;
  }

  .decoration-line {
    width: 50px;
    height: 4px;
    border-radius: 2px;
  }

  .decoration-gold {
    background-color: #F4C430;
  }

  .decoration-red {
    background-color: #E85D6A;
  }

  .header h1 {
    font-size: 3rem;
    font-weight: 700;
    color: #1a1a1a;
    margin-bottom: 10px;
    text-transform: uppercase;
    letter-spacing: 1px;
  }

  .header p {
    font-size: 1.1rem;
    color: #666;
    max-width: 600px;
    margin: 0 auto;
  }

  .carousel-container {
    position: relative;
    width: 100%;
    margin-bottom: 40px;
  }

  .carousel-wrapper {
    overflow: hidden;
    position: relative;
  }

  .carousel-track {
    display: flex;
    gap: 35px;
    transition: transform 0.5s ease;
    padding: 80px 0 40px;
  }

  .member-card {
    flex: 0 0 calc(25% - 26.25px);
    background: white;
    border-radius: 24px;
    overflow: visible;
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.12);
    transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
    cursor: pointer;
    position: relative;
  }

  .member-card:hover {
    transform: translateY(-15px);
    box-shadow: 0 20px 50px rgba(0, 0, 0, 0.18);
  }

  .member-cover {
    position: relative;
    height: 180px;
    background-size: cover;
    background-position: center;
    overflow: visible;
    border-radius: 24px 24px 0 0;
    background: #f5f5f5;
  }

  .member-cover::after {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background: linear-gradient(180deg, rgba(0,0,0,0) 0%, rgba(0,0,0,0.05) 100%);
    border-radius: 24px 24px 0 0;
  }

  .member-photo-overlay {
    position: absolute;
    bottom: -75px;
    left: 50%;
    transform: translateX(-50%);
    width: 180px;
    height: 180px;
    border-radius: 50%;
    border: 6px solid white;
    background: white;
    overflow: hidden;
    box-shadow: 0 8px 35px rgba(0, 0, 0, 0.25);
    z-index: 10;
    transition: all 0.3s ease;
  }

  .member-card:hover .member-photo-overlay {
    transform: translateX(-50%) scale(1.08);
    box-shadow: 0 12px 45px rgba(0, 0, 0, 0.3);
  }

  .member-photo-overlay img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .position-badge {
    position: absolute;
    top: 14px;
    right: 14px;
    background-color: #F4C430;
    color: #1a1a1a;
    padding: 8px 16px;
    border-radius: 25px;
    font-size: 0.7rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    box-shadow: 0 4px 15px rgba(244, 196, 48, 0.5);
    white-space: nowrap;
    transition: all 0.3s ease;
    z-index: 11;
  }

  .member-card:hover .position-badge {
    background-color: #FFD700;
    transform: scale(1.15);
  }

  .member-info {
    padding: 100px 22px 25px;
    text-align: center;
    overflow: hidden;
    border-radius: 0 0 24px 24px;
  }

  .member-name {
    font-size: 1.3rem;
    font-weight: 700;
    color: #1a1a1a;
    margin-bottom: 5px;
    line-height: 1.3;
  }

  .member-position {
    font-size: 0.85rem;
    color: #F4C430;
    font-weight: 700;
    margin-bottom: 12px;
    text-transform: uppercase;
    letter-spacing: 0.5px;
  }

  .member-bio {
    font-size: 0.9rem;
    color: #666;
    margin-bottom: 16px;
    line-height: 1.5;
    min-height: 45px;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .member-footer {
    border-top: 1px solid #f0f0f0;
    padding-top: 14px;
    margin-top: 14px;
  }

  .member-email {
    font-size: 0.82rem;
    color: #999;
    text-decoration: none;
    transition: color 0.3s ease;
    display: block;
    margin-bottom: 12px;
    word-break: break-all;
  }

  .member-email:hover {
    color: #F4C430;
  }

  .action-buttons {
    display: flex;
    gap: 10px;
    margin-top: 12px;
  }

  .view-profile-btn {
    flex: 1;
    background-color: #F4C430;
    color: #1a1a1a;
    padding: 10px 14px;
    border-radius: 8px;
    font-size: 0.85rem;
    font-weight: 600;
    text-decoration: none;
    border: none;
    cursor: pointer;
    transition: all 0.3s ease;
  }

  .view-profile-btn:hover {
    background-color: #FFD700;
    transform: translateY(-2px);
    box-shadow: 0 6px 16px rgba(244, 196, 48, 0.4);
  }

  .msg-btn {
    flex: 1;
    background-color: #f0f0f0;
    color: #1a1a1a;
    padding: 10px 14px;
    border-radius: 8px;
    font-size: 0.85rem;
    font-weight: 600;
    text-decoration: none;
    border: none;
    cursor: pointer;
    transition: all 0.3s ease;
  }

  .msg-btn:hover {
    background-color: #e8e8e8;
    transform: translateY(-2px);
  }

  .social-icons {
    display: flex;
    gap: 8px;
    justify-content: center;
    margin-top: 12px;
    padding-top: 12px;
    border-top: 1px solid #f0f0f0;
    opacity: 0;
    transition: opacity 0.3s ease;
  }

  .member-card:hover .social-icons {
    opacity: 1;
  }

  .social-icon {
    width: 40px;
    height: 40px;
    background-color: #f5f5f5;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    text-decoration: none;
    color: #F4C430;
    font-weight: bold;
    font-size: 1rem;
    transition: all 0.3s ease;
    border: 1px solid #f0f0f0;
  }

  .social-icon:hover {
    background-color: #F4C430;
    color: #1a1a1a;
    transform: translateY(-3px);
    box-shadow: 0 6px 15px rgba(244, 196, 48, 0.35);
  }

  .carousel-nav {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    background-color: white;
    color: #1a1a1a;
    border: 2px solid #F4C430;
    width: 55px;
    height: 55px;
    border-radius: 50%;
    font-size: 1.8rem;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: all 0.3s ease;
    z-index: 10;
    box-shadow: 0 4px 15px rgba(0, 0, 0, 0.15);
  }

  .carousel-nav:hover {
    background-color: #F4C430;
    color: white;
    transform: translateY(-50%) scale(1.2);
    box-shadow: 0 8px 25px rgba(244, 196, 48, 0.4);
  }

  .carousel-nav.prev {
    left: -35px;
  }

  .carousel-nav.next {
    right: -35px;
  }

  .carousel-dots {
    display: flex;
    justify-content: center;
    gap: 12px;
    margin-top: 50px;
  }

  .dot {
    width: 14px;
    height: 14px;
    border-radius: 50%;
    background-color: #ddd;
    cursor: pointer;
    transition: all 0.3s ease;
  }

  .dot.active {
    background-color: #F4C430;
    width: 36px;
    border-radius: 7px;
    box-shadow: 0 2px 10px rgba(244, 196, 48, 0.35);
  }

  .dot:hover {
    background-color: #F4C430;
  }

  @media (max-width: 1200px) {
    .member-card {
      flex: 0 0 calc(33.333% - 23.33px);
    }

    .carousel-track {
      gap: 30px;
    }
  }

  @media (max-width: 768px) {
    .header h1 {
      font-size: 2rem;
    }

    .member-card {
      flex: 0 0 calc(50% - 17.5px);
    }

    .carousel-nav {
      width: 45px;
      height: 45px;
      font-size: 1.4rem;
    }

    .carousel-nav.prev {
      left: -22px;
    }

    .carousel-nav.next {
      right: -22px;
    }

    .member-photo-overlay {
      width: 150px;
      height: 150px;
      bottom: -60px;
    }

    .member-cover {
      height: 150px;
    }

    .member-info {
      padding: 85px 18px 20px;
    }

    .carousel-track {
      padding: 70px 0 30px;
    }
  }

  @media (max-width: 480px) {
    .header h1 {
      font-size: 1.5rem;
    }

    .member-card {
      flex: 0 0 100%;
    }

    .carousel-nav {
      width: 40px;
      height: 40px;
      font-size: 1.2rem;
    }

    .carousel-nav.prev {
      left: 5px;
    }

    .carousel-nav.next {
      right: 5px;
    }

    .committee-carousel {
      padding: 20px 10px;
    }

    .carousel-wrapper {
      margin: 0 35px;
    }

    .member-photo-overlay {
      width: 130px;
      height: 130px;
      bottom: -50px;
    }

    .action-buttons {
      flex-direction: column;
      gap: 8px;
    }

    .member-info {
      padding: 75px 15px 18px;
    }

    .carousel-track {
      padding: 60px 0 25px;
      gap: 20px;
    }
  }

  @keyframes fadeInUp {
    from {
      opacity: 0;
      transform: translateY(30px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .carousel-container {
    animation: fadeInUp 0.6s ease;
  }

  .member-card {
    opacity: 0;
    animation: fadeInUp 0.6s ease forwards;
  }

  .card-1 { animation-delay: 0.1s; }
  .card-2 { animation-delay: 0.2s; }
  .card-3 { animation-delay: 0.3s; }
  .card-4 { animation-delay: 0.4s; }
  .card-5 { animation-delay: 0.5s; }
  .card-6 { animation-delay: 0.6s; }

  html {
    scroll-behavior: smooth;
  }
</style>

<script>
  document.addEventListener('DOMContentLoaded', function() {
    const track = document.getElementById('committeeCarouselTrack') as HTMLElement | null;
    const prevBtn = document.getElementById('committeePrevBtn') as HTMLElement | null;
    const nextBtn = document.getElementById('committeeNextBtn') as HTMLElement | null;
    const dotsContainer = document.getElementById('committeeDots') as HTMLElement | null;
    const cards = track ? track.querySelectorAll<HTMLElement>('.member-card') : (null as unknown as NodeListOf<HTMLElement>);

    if (!track || !prevBtn || !nextBtn || !dotsContainer || cards.length === 0) return;

    const trackEl = track;
    const dotsEl = dotsContainer;
    let currentIndex = 0;
    let cardsPerView = getCardsPerView();
    const gap = 35;

    function getCardsPerView() {
      const width = window.innerWidth;
      if (width < 480) return 1;
      if (width < 768) return 2;
      if (width < 1200) return 3;
      return 4;
    }

    function createDots() {
      dotsEl.innerHTML = '';
      const maxIndex = cards.length - cardsPerView;
      const totalSlides = Math.max(1, maxIndex + 1);

      for (let i = 0; i < totalSlides; i++) {
        const dot = document.createElement('div');
        dot.className = `dot${i === 0 ? ' active' : ''}`;
        dot.onclick = () => goToSlide(i);
        dotsEl.appendChild(dot);
      }
    }

    function updateCarousel() {
      const cardWidth = (cards[0] as HTMLElement).offsetWidth;
      const offset = -(currentIndex * (cardWidth + gap));
      trackEl.style.transform = `translateX(${offset}px)`;
      updateDots();
    }

    function updateDots() {
      const dots = dotsEl.querySelectorAll<HTMLElement>('.dot');
      dots.forEach((dot, index) => dot.classList.toggle('active', index === currentIndex));
    }

    function goToSlide(index: number) {
      const maxIndex = Math.max(0, cards.length - cardsPerView);
      currentIndex = Math.max(0, Math.min(index, maxIndex));
      updateCarousel();
    }

    prevBtn.addEventListener('click', () => goToSlide(currentIndex - 1));
    nextBtn.addEventListener('click', () => goToSlide(currentIndex + 1));

    function handleResize() {
      const newCardsPerView = getCardsPerView();
      if (newCardsPerView !== cardsPerView) {
        cardsPerView = newCardsPerView;
        currentIndex = 0;
        createDots();
        updateCarousel();
      }
    }

    createDots();
    updateCarousel();
    window.addEventListener('resize', handleResize);
    document.addEventListener('keydown', (e) => {
      if (e.key === 'ArrowLeft') goToSlide(currentIndex - 1);
      if (e.key === 'ArrowRight') goToSlide(currentIndex + 1);
    });
  });
</script>
