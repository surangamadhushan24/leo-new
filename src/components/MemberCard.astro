---
interface Props {
  name: string;
  position: string;
  image: string;
}

const { name, position, image } = Astro.props;
---

<div class="member-card">
  <div class="card border-0 shadow-sm text-center h-100" style="border-radius: 16px; overflow: hidden; transition: all 0.3s ease; background: linear-gradient(145deg, #ffffff 0%, #f8fafc 100%);">
    <div class="card-image-container" style="position: relative; overflow: hidden;">
      <img src={image} class="card-img-top" alt={name} style="width: 100%; height: 280px; object-fit: cover; transition: transform 0.4s ease;">
      <div class="card-overlay" style="position: absolute; top: 0; left: 0; right: 0; bottom: 0; background: linear-gradient(135deg, rgba(255, 193, 7, 0.1) 0%, rgba(196, 30, 58, 0.05) 100%); opacity: 0; transition: opacity 0.3s ease;"></div>
    </div>

    <div class="card-body" style="padding: 24px;">
      <h5 class="card-title" style="font-size: 1.25rem; font-weight: 700; color: #1a1a2e; margin-bottom: 8px; letter-spacing: -0.5px;">{name}</h5>
      <p class="card-text text-warning" style="font-size: 0.9rem; font-weight: 600; margin: 0; text-transform: uppercase; letter-spacing: 1px;">{position}</p>

      <!-- Decorative accent -->
      <div class="card-accent" style="width: 40px; height: 3px; background: linear-gradient(to right, #ffc107, #c41e3a); border-radius: 2px; margin: 16px auto 0; opacity: 0; transform: scaleX(0); transition: all 0.3s ease; transform-origin: center;"></div>
    </div>
  </div>
</div>

<style>
  .member-card {
    height: 100%;
  }

  .member-card:hover .card {
    transform: translateY(-8px);
    box-shadow: 0 12px 32px rgba(0, 0, 0, 0.15);
  }

  .member-card:hover .card-img-top {
    transform: scale(1.05);
  }

  .member-card:hover .card-overlay {
    opacity: 1;
  }

  .member-card:hover .card-accent {
    opacity: 1;
    transform: scaleX(1);
  }

  .card-title:hover {
    color: #c41e3a !important;
  }
</style>
