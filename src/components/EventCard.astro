---
export interface Props {
  event: any;
}

const { event } = Astro.props;
const { frontmatter } = event;

const getSlug = () => {
  const filePath = (event as any).file || '';
  const fileName = filePath.split(/[\/\\]/).pop() || '';
  const slug = fileName.replace('.md', '').trim();
  if (slug) return slug;
  return frontmatter.title?.toLowerCase().replace(/\s+/g, '-') || 'event';
};

const slug = getSlug();
---

<div class="event-card h-100">
  <div class="event-header">
    {frontmatter.image && (
      <img src={frontmatter.image} class="event-image" alt={frontmatter.title}>
    )}
    <div class="event-header-overlay"></div>
    <h5 class="event-title">{frontmatter.title}</h5>
  </div>
  
  <div class="event-content">
    {frontmatter.date && (
      <div class="event-detail">
        <div class="detail-icon calendar">
          <i class="fas fa-calendar-alt"></i>
        </div>
        <div class="detail-text">
          <span class="detail-label">Date</span>
          <span class="detail-value">
            {new Date(frontmatter.date).toLocaleDateString('en-US', { 
              weekday: 'short', 
              month: 'short', 
              day: 'numeric' 
            })}
          </span>
        </div>
      </div>
    )}
    
    {frontmatter.time && (
      <div class="event-detail">
        <div class="detail-icon time">
          <i class="fas fa-clock"></i>
        </div>
        <div class="detail-text">
          <span class="detail-label">Time</span>
          <span class="detail-value">{frontmatter.time}</span>
        </div>
      </div>
    )}
    
    {frontmatter.location && (
      <div class="event-detail">
        <div class="detail-icon location">
          <i class="fas fa-map-marker-alt"></i>
        </div>
        <div class="detail-text">
          <span class="detail-label">Location</span>
          <span class="detail-value">{frontmatter.location}</span>
        </div>
      </div>
    )}
    
    <a href={`/events/${slug}`} class="btn-event-details">
      More Details <i class="fas fa-arrow-right ms-2"></i>
    </a>
  </div>
</div>

<style>
  .event-card {
    border: none;
    border-radius: 12px;
    overflow: hidden;
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.12);
    transition: all 0.3s ease;
    background: white;
    display: flex;
    flex-direction: column;
  }

  .event-card:hover {
    transform: translateY(-12px);
    box-shadow: 0 16px 40px rgba(196, 30, 58, 0.2);
  }

  .event-header {
    position: relative;
    height: 180px;
    overflow: hidden;
    display: flex;
    align-items: flex-end;
  }

  .event-image {
    position: absolute;
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.3s ease;
  }

  .event-card:hover .event-image {
    transform: scale(1.08);
  }

  .event-header-overlay {
    position: absolute;
    width: 100%;
    height: 100%;
    background: linear-gradient(180deg, rgba(0,0,0,0) 0%, rgba(0,0,0,0.6) 100%);
  }

  .event-title {
    position: relative;
    z-index: 2;
    color: white;
    font-weight: 700;
    font-size: 1.1rem;
    padding: 0 20px 20px;
    line-height: 1.3;
    margin: 0;
  }

  .event-content {
    padding: 24px;
    flex-grow: 1;
    display: flex;
    flex-direction: column;
  }

  .event-detail {
    display: flex;
    gap: 16px;
    margin-bottom: 16px;
    padding-bottom: 16px;
    border-bottom: 1px solid #f0f0f0;
    align-items: flex-start;
  }

  .event-detail:last-of-type {
    border-bottom: none;
    margin-bottom: 20px;
  }

  .detail-icon {
    width: 40px;
    height: 40px;
    border-radius: 8px;
    display: flex;
    align-items: center;
    justify-content: center;
    color: white;
    font-size: 0.9rem;
    flex-shrink: 0;
  }

  .detail-icon.calendar {
    background: linear-gradient(135deg, #ffc107, #ffb300);
  }

  .detail-icon.time {
    background: linear-gradient(135deg, #c41e3a, #a01830);
  }

  .detail-icon.location {
    background: linear-gradient(135deg, #1a1a2e, #0f0f1e);
  }

  .detail-text {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .detail-label {
    font-size: 0.75rem;
    color: #999;
    text-transform: uppercase;
    font-weight: 600;
    letter-spacing: 0.5px;
  }

  .detail-value {
    font-size: 0.95rem;
    color: #333;
    font-weight: 500;
  }

  .btn-event-details {
    display: inline-flex;
    align-items: center;
    color: #ffc107;
    text-decoration: none;
    font-weight: 600;
    font-size: 0.95rem;
    transition: all 0.3s ease;
    margin-top: auto;
  }

  .btn-event-details:hover {
    color: #c41e3a;
  }

  .btn-event-details i {
    transition: transform 0.3s ease;
  }

  .btn-event-details:hover i {
    transform: translateX(4px);
  }
</style>