---
export interface Props {
  event: any;
}

const { event } = Astro.props;
const { frontmatter } = event;

const getSlug = () => {
  const filePath = (event as any).file || '';
  const fileName = filePath.split(/[\/\\]/).pop() || '';
  const slug = fileName.replace('.md', '').trim();
  if (slug) return slug;
  return frontmatter.title?.toLowerCase().replace(/\s+/g, '-') || 'event';
};

const slug = getSlug();
---

<div class="event-card h-100">
  <div class="event-hero">
    {frontmatter.image ? (
      <img src={frontmatter.image} class="event-image" alt={frontmatter.title} />
    ) : (
      <div class="event-image event-image-fallback"></div>
    )}
    <div class="event-hero-overlay"></div>
    <div class="event-hero-text">
      <span class="event-label">Upcoming Event</span>
      <h5 class="event-title">{frontmatter.title}</h5>
    </div>
  </div>

  <div class="event-info">
    <div class="event-meta">
      {frontmatter.date && (
        <div class="event-detail">
          <div class="detail-icon calendar">
            <i class="fas fa-calendar-alt"></i>
          </div>
          <div class="detail-text">
            <span class="detail-label">Date</span>
            <span class="detail-value">{new Date(frontmatter.date).toLocaleDateString('en-US', { weekday: 'short', month: 'short', day: 'numeric' })}</span>
          </div>
        </div>
      )}
      {frontmatter.time && (
        <div class="event-detail">
          <div class="detail-icon time">
            <i class="fas fa-clock"></i>
          </div>
          <div class="detail-text">
            <span class="detail-label">Time</span>
            <span class="detail-value">{frontmatter.time}</span>
          </div>
        </div>
      )}
      {frontmatter.location && (
        <div class="event-detail">
          <div class="detail-icon location">
            <i class="fas fa-map-marker-alt"></i>
          </div>
          <div class="detail-text">
            <span class="detail-label">Location</span>
            <span class="detail-value">{frontmatter.location}</span>
          </div>
        </div>
      )}
    </div>

    <a href={`/events/${slug}`} class="event-cta">
      See Details <i class="fas fa-arrow-right"></i>
    </a>
  </div>
</div>

<style>
  .event-card {
    border: none;
    border-radius: 24px;
    overflow: hidden;
    background: white;
    display: flex;
    flex-direction: column;
    min-height: 100%;
    box-shadow: 0 18px 45px rgba(15, 23, 42, 0.08);
    transition: transform 0.4s ease, box-shadow 0.4s ease;
    position: relative;
  }

  .event-card:hover {
    transform: translateY(-14px);
    box-shadow: 0 26px 60px rgba(15, 23, 42, 0.14);
  }

  .event-hero {
    position: relative;
    height: 260px;
    overflow: hidden;
    background: #f3f4f6;
    display: flex;
    align-items: flex-end;
  }

  .event-image,
  .event-image-fallback {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .event-image-fallback {
    background: linear-gradient(135deg, #4facfe 0%, #00f2fe 100%);
  }

  .event-card:hover .event-image {
    transform: scale(1.08);
  }

  .event-hero-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(180deg, rgba(15, 23, 42, 0.08) 0%, rgba(15, 23, 42, 0.6) 100%);
  }

  .event-hero-text {
    position: relative;
    z-index: 2;
    padding: 24px 28px 28px;
  }

  .event-label {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 10px 16px;
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.95);
    color: #1f2937;
    font-size: 0.75rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    margin-bottom: 16px;
  }

  .event-title {
    color: white;
    font-size: 1.7rem;
    line-height: 1.1;
    font-weight: 800;
    margin: 0;
    letter-spacing: -0.5px;
  }

  .event-info {
    padding: 32px;
    display: flex;
    flex-direction: column;
    gap: 26px;
    flex-grow: 1;
  }

  .event-meta {
    display: flex;
    flex-direction: column;
    gap: 18px;
  }

  .event-detail {
    display: flex;
    gap: 18px;
    padding: 18px;
    border-radius: 24px;
    background: #f8fafc;
    border: 1px solid rgba(15, 23, 42, 0.05);
    transition: transform 0.3s ease, border-color 0.3s ease, background 0.3s ease;
  }

  .event-detail:hover {
    transform: translateY(-2px);
    background: #fff7e6;
    border-color: rgba(255, 193, 7, 0.25);
  }

  .detail-icon {
    width: 48px;
    height: 48px;
    border-radius: 16px;
    display: flex;
    align-items: center;
    justify-content: center;
    color: white;
    font-size: 1.1rem;
    flex-shrink: 0;
    transition: transform 0.3s ease;
  }

  .detail-icon.calendar {
    background: linear-gradient(135deg, #ffc107, #ffb300);
    box-shadow: 0 10px 25px rgba(255, 193, 7, 0.18);
  }

  .detail-icon.time {
    background: linear-gradient(135deg, #c41e3a, #a01830);
    box-shadow: 0 10px 25px rgba(196, 30, 58, 0.18);
  }

  .detail-icon.location {
    background: linear-gradient(135deg, #1a1a2e, #0f0f1e);
    box-shadow: 0 10px 25px rgba(26, 26, 46, 0.18);
  }

  .event-detail:hover .detail-icon {
    transform: scale(1.05);
  }

  .detail-text {
    display: flex;
    flex-direction: column;
    gap: 6px;
  }

  .detail-label {
    font-size: 0.7rem;
    color: #6b7280;
    text-transform: uppercase;
    font-weight: 700;
    letter-spacing: 1px;
  }

  .detail-value {
    font-size: 1rem;
    color: #111827;
    font-weight: 700;
  }

  .event-cta {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 10px;
    padding: 14px 24px;
    border-radius: 16px;
    background: linear-gradient(135deg, #ffc107, #ffb300);
    color: #1f2937;
    font-size: 0.95rem;
    font-weight: 700;
    text-decoration: none;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    box-shadow: 0 12px 24px rgba(255, 193, 7, 0.18);
    transition: transform 0.3s ease, box-shadow 0.3s ease;
    align-self: flex-start;
  }

  .event-cta:hover {
    transform: translateY(-2px);
    box-shadow: 0 18px 32px rgba(255, 193, 7, 0.25);
  }
</style>