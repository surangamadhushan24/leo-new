---
export interface Props {
  event: any;
}

const { event } = Astro.props;
const { frontmatter } = event;

const getSlug = () => {
  const filePath = (event as any).file || '';
  const fileName = filePath.split(/[\/\\]/).pop() || '';
  const slug = fileName.replace('.md', '').trim();
  if (slug) return slug;
  return frontmatter.title?.toLowerCase().replace(/\s+/g, '-') || 'event';
};

const slug = getSlug();
---

<div class="event-card h-100">
  <div class="event-header">
    {frontmatter.image && (
      <img src={frontmatter.image} class="event-image" alt={frontmatter.title}>
    )}
    <div class="event-header-overlay"></div>
    <h5 class="event-title">{frontmatter.title}</h5>
  </div>
  
  <div class="event-content">
    {frontmatter.date && (
      <div class="event-detail">
        <div class="detail-icon calendar">
          <i class="fas fa-calendar-alt"></i>
        </div>
        <div class="detail-text">
          <span class="detail-label">Date</span>
          <span class="detail-value">
            {new Date(frontmatter.date).toLocaleDateString('en-US', { 
              weekday: 'short', 
              month: 'short', 
              day: 'numeric' 
            })}
          </span>
        </div>
      </div>
    )}
    
    {frontmatter.time && (
      <div class="event-detail">
        <div class="detail-icon time">
          <i class="fas fa-clock"></i>
        </div>
        <div class="detail-text">
          <span class="detail-label">Time</span>
          <span class="detail-value">{frontmatter.time}</span>
        </div>
      </div>
    )}
    
    {frontmatter.location && (
      <div class="event-detail">
        <div class="detail-icon location">
          <i class="fas fa-map-marker-alt"></i>
        </div>
        <div class="detail-text">
          <span class="detail-label">Location</span>
          <span class="detail-value">{frontmatter.location}</span>
        </div>
      </div>
    )}
    
    <a href={`/events/${slug}`} class="btn-event-details">
      More Details <i class="fas fa-arrow-right ms-2"></i>
    </a>
  </div>
</div>

<style>
  .event-card {
    border: none;
    border-radius: 16px;
    overflow: hidden;
    box-shadow: 0 10px 30px rgba(0, 0, 0, 0.12);
    transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
    background: white;
    display: flex;
    flex-direction: column;
    position: relative;
  }

  .event-card::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 4px;
    background: linear-gradient(to right, #ffc107, #c41e3a);
    transform: scaleX(0);
    transition: transform 0.4s cubic-bezier(0.4, 0, 0.2, 1);
    transform-origin: left;
    z-index: 10;
  }

  .event-card:hover::before {
    transform: scaleX(1);
  }

  .event-card:hover {
    transform: translateY(-16px);
    box-shadow: 0 20px 50px rgba(196, 30, 58, 0.2);
  }

  .event-header {
    position: relative;
    height: 200px;
    overflow: hidden;
    display: flex;
    align-items: flex-end;
  }

  .event-image {
    position: absolute;
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.5s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .event-card:hover .event-image {
    transform: scale(1.12);
  }

  .event-header-overlay {
    position: absolute;
    width: 100%;
    height: 100%;
    background: linear-gradient(180deg, rgba(0,0,0,0.2) 0%, rgba(26, 26, 46, 0.9) 100%);
  }

  .event-title {
    position: relative;
    z-index: 2;
    color: white;
    font-weight: 800;
    font-size: 1.2rem;
    padding: 0 20px 20px;
    line-height: 1.4;
    margin: 0;
    letter-spacing: -0.5px;
  }

  .event-content {
    padding: 28px;
    flex-grow: 1;
    display: flex;
    flex-direction: column;
  }

  .event-detail {
    display: flex;
    gap: 16px;
    margin-bottom: 18px;
    padding-bottom: 18px;
    border-bottom: 2px solid #f3f4f6;
    align-items: flex-start;
    transition: all 0.3s ease;
  }

  .event-detail:hover {
    border-bottom-color: #ffc107;
    padding-left: 8px;
  }

  .event-detail:last-of-type {
    border-bottom: none;
    margin-bottom: 24px;
  }

  .detail-icon {
    width: 44px;
    height: 44px;
    border-radius: 10px;
    display: flex;
    align-items: center;
    justify-content: center;
    color: white;
    font-size: 1rem;
    flex-shrink: 0;
    transition: all 0.3s ease;
  }

  .detail-icon.calendar {
    background: linear-gradient(135deg, #ffc107, #ffb300);
    box-shadow: 0 4px 15px rgba(255, 193, 7, 0.3);
  }

  .event-detail:hover .detail-icon.calendar {
    transform: rotate(360deg) scale(1.1);
  }

  .detail-icon.time {
    background: linear-gradient(135deg, #c41e3a, #a01830);
    box-shadow: 0 4px 15px rgba(196, 30, 58, 0.3);
  }

  .event-detail:hover .detail-icon.time {
    transform: rotate(360deg) scale(1.1);
  }

  .detail-icon.location {
    background: linear-gradient(135deg, #1a1a2e, #0f0f1e);
    box-shadow: 0 4px 15px rgba(26, 26, 46, 0.3);
  }

  .event-detail:hover .detail-icon.location {
    transform: rotate(360deg) scale(1.1);
  }

  .detail-text {
    display: flex;
    flex-direction: column;
    gap: 6px;
  }

  .detail-label {
    font-size: 0.7rem;
    color: #9ca3af;
    text-transform: uppercase;
    font-weight: 700;
    letter-spacing: 1px;
  }

  .detail-value {
    font-size: 1rem;
    color: #1f2937;
    font-weight: 600;
  }

  .btn-event-details {
    display: inline-flex;
    align-items: center;
    color: #ffc107;
    text-decoration: none;
    font-weight: 700;
    font-size: 0.95rem;
    transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    margin-top: auto;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    position: relative;
  }

  .btn-event-details::after {
    content: '';
    position: absolute;
    bottom: -3px;
    left: 0;
    width: 0;
    height: 2px;
    background: #ffc107;
    transition: width 0.3s ease;
  }

  .btn-event-details:hover {
    color: #c41e3a;
  }

  .btn-event-details:hover::after {
    width: 100%;
    background: #c41e3a;
  }

  .btn-event-details i {
    transition: transform 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    margin-left: 8px;
  }

  .btn-event-details:hover i {
    transform: translateX(6px);
  }
</style>