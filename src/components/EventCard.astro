---
export interface Props {
  event: any;
}

const { event } = Astro.props;
const { frontmatter } = event;

const getSlug = () => {
  const filePath = (event as any).file || '';
  const fileName = filePath.split(/[\/\\]/).pop() || '';
  const slug = fileName.replace('.md', '').trim();
  if (slug) return slug;
  return frontmatter.title?.toLowerCase().replace(/\s+/g, '-') || 'event';
};

const slug = getSlug();

const formatDate = (dateStr: string) => {
  const d = new Date(dateStr);
  return {
    day:     d.toLocaleDateString('en-US', { day: '2-digit' }),
    month:   d.toLocaleDateString('en-US', { month: 'short' }).toUpperCase(),
    weekday: d.toLocaleDateString('en-US', { weekday: 'long' }),
    full:    d.toLocaleDateString('en-US', { weekday: 'short', month: 'short', day: 'numeric', year: 'numeric' }),
  };
};

const date = frontmatter.date ? formatDate(frontmatter.date) : null;
---

<article class="ev-card">
  <!-- Image / Hero -->
  <div class="ev-hero">
    {frontmatter.image ? (
      <img src={frontmatter.image} class="ev-img" alt={frontmatter.title} loading="lazy" />
    ) : (
      <div class="ev-img ev-img-fallback"></div>
    )}
    <div class="ev-overlay"></div>

    <!-- Floating date badge -->
    {date && (
      <div class="ev-date-badge">
        <span class="ev-date-day">{date.day}</span>
        <span class="ev-date-month">{date.month}</span>
      </div>
    )}

    <!-- "Upcoming" pill -->
    <span class="ev-status-pill">
      <span class="ev-status-dot"></span>
      Upcoming
    </span>
  </div>

  <!-- Body -->
  <div class="ev-body">
    <h3 class="ev-title">{frontmatter.title}</h3>

    <div class="ev-details">
      {date && (
        <div class="ev-detail-row">
          <div class="ev-detail-icon ev-icon-gold">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
              <rect x="3" y="4" width="18" height="18" rx="2" ry="2"></rect>
              <line x1="16" y1="2" x2="16" y2="6"></line>
              <line x1="8" y1="2" x2="8" y2="6"></line>
              <line x1="3" y1="10" x2="21" y2="10"></line>
            </svg>
          </div>
          <div class="ev-detail-content">
            <span class="ev-detail-label">Date</span>
            <span class="ev-detail-value">{date.full}</span>
          </div>
        </div>
      )}

      {frontmatter.time && (
        <div class="ev-detail-row">
          <div class="ev-detail-icon ev-icon-navy">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
              <circle cx="12" cy="12" r="10"></circle>
              <polyline points="12 6 12 12 16 14"></polyline>
            </svg>
          </div>
          <div class="ev-detail-content">
            <span class="ev-detail-label">Time</span>
            <span class="ev-detail-value">{frontmatter.time}</span>
          </div>
        </div>
      )}

      {frontmatter.location && (
        <div class="ev-detail-row">
          <div class="ev-detail-icon ev-icon-red">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"></path>
              <circle cx="12" cy="10" r="3"></circle>
            </svg>
          </div>
          <div class="ev-detail-content">
            <span class="ev-detail-label">Location</span>
            <span class="ev-detail-value">{frontmatter.location}</span>
          </div>
        </div>
      )}
    </div>

    <a href={`/events/${slug}`} class="ev-cta">
      See Details
      <svg class="ev-cta-arrow" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
        <line x1="5" y1="12" x2="19" y2="12"></line>
        <polyline points="12 5 19 12 12 19"></polyline>
      </svg>
    </a>
  </div>
</article>

<style>
  /* ── Card shell ─────────────────────────────── */
  .ev-card {
    background: var(--lighter-bg);
    border-radius: 20px;
    overflow: hidden;
    display: flex;
    flex-direction: column;
    height: 100%;
    box-shadow:
      0 1px 2px rgba(26, 26, 46, 0.04),
      0 4px 16px rgba(26, 26, 46, 0.07),
      0 12px 32px rgba(26, 26, 46, 0.06);
    border: 1px solid rgba(26, 26, 46, 0.07);
    transition: transform 0.35s cubic-bezier(0.34, 1.56, 0.64, 1),
                box-shadow 0.35s ease;
    position: relative;
  }

  .ev-card:hover {
    transform: translateY(-10px);
    box-shadow:
      0 2px 4px rgba(26, 26, 46, 0.05),
      0 12px 32px rgba(26, 26, 46, 0.10),
      0 28px 56px rgba(26, 26, 46, 0.10);
  }

  /* ── Hero image area ────────────────────────── */
  .ev-hero {
    position: relative;
    height: 220px;
    overflow: hidden;
    background: var(--secondary-color);
    flex-shrink: 0;
  }

  .ev-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.55s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .ev-card:hover .ev-img { transform: scale(1.07); }

  .ev-img-fallback {
    background: linear-gradient(135deg, var(--secondary-color) 0%, var(--secondary-light) 50%, var(--accent-color) 100%);
  }

  /* Gradient overlay */
  .ev-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      180deg,
      rgba(26, 26, 46, 0.10) 0%,
      rgba(26, 26, 46, 0.55) 100%
    );
  }

  /* ── Date badge (top-left corner) ───────────── */
  .ev-date-badge {
    position: absolute;
    top: 16px;
    left: 16px;
    background: linear-gradient(135deg, #ffc107, #e6a800);
    border-radius: 12px;
    padding: 8px 14px;
    display: flex;
    flex-direction: column;
    align-items: center;
    line-height: 1;
    box-shadow: 0 4px 16px rgba(255, 193, 7, 0.45);
    z-index: 3;
  }

  .ev-date-day {
    font-size: 1.6rem;
    font-weight: 800;
    color: #1a1a2e;
    letter-spacing: -1px;
    line-height: 1;
  }

  .ev-date-month {
    font-size: 0.65rem;
    font-weight: 800;
    color: #1a1a2e;
    letter-spacing: 1px;
    margin-top: 2px;
  }

  /* ── Status pill (top-right) ────────────────── */
  .ev-status-pill {
    position: absolute;
    top: 16px;
    right: 16px;
    display: inline-flex;
    align-items: center;
    gap: 6px;
    background: var(--lighter-bg);
    backdrop-filter: blur(8px);
    border-radius: 100px;
    padding: 6px 12px;
    font-size: 0.72rem;
    font-weight: 700;
    color: #1a1a2e;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    z-index: 3;
  }

  .ev-status-dot {
    width: 7px;
    height: 7px;
    border-radius: 50%;
    background: var(--success-color);
    box-shadow: 0 0 0 2px rgba(34, 197, 94, 0.25);
    animation: pulse 2s ease infinite;
  }

  @keyframes pulse {
    0%, 100% { box-shadow: 0 0 0 2px rgba(34, 197, 94, 0.25); }
    50%       { box-shadow: 0 0 0 5px rgba(34, 197, 94, 0.10); }
  }

  /* ── Card body ──────────────────────────────── */
  .ev-body {
    padding: 24px;
    display: flex;
    flex-direction: column;
    gap: 20px;
    flex-grow: 1;
  }

  .ev-title {
    font-size: 1.15rem;
    font-weight: 800;
    color: #1a1a2e;
    line-height: 1.3;
    letter-spacing: -0.02em;
    margin: 0;
  }

  /* ── Detail rows ────────────────────────────── */
  .ev-details {
    display: flex;
    flex-direction: column;
    gap: 10px;
    flex-grow: 1;
  }

  .ev-detail-row {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 11px 14px;
    border-radius: 12px;
    background: #f7f7f5;
    border: 1px solid rgba(26, 26, 46, 0.05);
    transition: background 0.2s, border-color 0.2s, transform 0.2s;
  }

  .ev-detail-row:hover {
    background: #fff8e1;
    border-color: rgba(255, 193, 7, 0.25);
    transform: translateX(3px);
  }

  .ev-detail-icon {
    width: 36px;
    height: 36px;
    border-radius: 10px;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    color: white;
  }

  .ev-icon-gold  { background: linear-gradient(135deg, var(--primary-color), var(--primary-dark)); color: var(--secondary-color); }
  .ev-icon-navy  { background: linear-gradient(135deg, var(--secondary-color), var(--secondary-light)); }
  .ev-icon-red   { background: linear-gradient(135deg, var(--accent-color), var(--accent-dark)); }

  .ev-detail-content {
    display: flex;
    flex-direction: column;
    gap: 2px;
    min-width: 0;
  }

  .ev-detail-label {
    font-size: 0.65rem;
    font-weight: 700;
    color: #9ca3af;
    text-transform: uppercase;
    letter-spacing: 0.8px;
  }

  .ev-detail-value {
    font-size: 0.9rem;
    font-weight: 700;
    color: #1a1a2e;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  /* ── CTA button ─────────────────────────────── */
  .ev-cta {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    padding: 13px 20px;
    border-radius: 12px;
    background: linear-gradient(135deg, var(--secondary-color) 0%, var(--secondary-light) 100%);
    color: #ffffff;
    font-size: 0.88rem;
    font-weight: 700;
    text-decoration: none;
    letter-spacing: 0.3px;
    transition: background 0.25s, transform 0.25s, box-shadow 0.25s;
    box-shadow: 0 4px 14px rgba(26, 26, 46, 0.20);
    align-self: stretch;
    margin-top: auto;
  }

  .ev-cta:hover {
    background: linear-gradient(135deg, var(--primary-color) 0%, var(--primary-dark) 100%);
    color: #1a1a2e;
    transform: translateY(-2px);
    box-shadow: 0 8px 22px rgba(255, 193, 7, 0.35);
    text-decoration: none;
  }

  .ev-cta-arrow {
    transition: transform 0.25s ease;
    flex-shrink: 0;
  }

  .ev-cta:hover .ev-cta-arrow { transform: translateX(4px); }
</style>