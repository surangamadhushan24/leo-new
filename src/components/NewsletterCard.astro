---
export interface Props {
  newsletter: any;
}

const { newsletter } = Astro.props;
const { frontmatter } = newsletter;

const getPreview = () => {
  if (frontmatter.description) {
    return frontmatter.description.split(' ').slice(0, 30).join(' ');
  }
  return '';
};

const getSlug = () => {
  const filePath = (newsletter as any).file || '';
  const fileName = filePath.split(/[\/\\]/).pop() || '';
  const slug = fileName.replace('.md', '').trim();
  if (slug) return slug;
  return frontmatter.title?.toLowerCase().replace(/\s+/g, '-') || 'newsletter';
};

const preview = getPreview();
const slug = getSlug();
---

<div class="newsletter-card h-100">
  <div class="newsletter-badge">
    <i class="fas fa-envelope"></i> Newsletter
  </div>
  
  <div class="newsletter-image-wrapper">
    {frontmatter.image && (
      <img src={frontmatter.image} class="newsletter-img" alt={frontmatter.title}>
    )}
    <div class="newsletter-overlay"></div>
  </div>
  
  <div class="newsletter-content">
    <h5 class="newsletter-title">{frontmatter.title}</h5>
    
    {frontmatter.date && (
      <p class="newsletter-date">
        <i class="fas fa-calendar-alt me-2"></i>
        {new Date(frontmatter.date).toLocaleDateString('en-US', { 
          year: 'numeric', 
          month: 'long', 
          day: 'numeric' 
        })}
      </p>
    )}
    
    <p class="newsletter-description">{preview}{preview && '...'}</p>
    
    <a href={`/newsletter/${slug}`} class="btn-read-newsletter">
      Read Latest <i class="fas fa-arrow-right ms-2"></i>
    </a>
  </div>
</div>

<style>
  .newsletter-card {
    border: none;
    border-radius: 16px;
    overflow: hidden;
    box-shadow: 0 10px 30px rgba(0, 0, 0, 0.12);
    transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
    background: white;
    display: flex;
    flex-direction: column;
    position: relative;
  }

  .newsletter-card::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 4px;
    background: linear-gradient(to right, #ffc107, #c41e3a);
    transform: scaleX(0);
    transition: transform 0.4s cubic-bezier(0.4, 0, 0.2, 1);
    transform-origin: left;
    z-index: 10;
  }

  .newsletter-card:hover::before {
    transform: scaleX(1);
  }

  .newsletter-card:hover {
    transform: translateY(-16px);
    box-shadow: 0 20px 50px rgba(255, 193, 7, 0.2);
  }

  .newsletter-badge {
    position: absolute;
    top: 16px;
    left: 16px;
    background: linear-gradient(135deg, #c41e3a, #a01830);
    color: white;
    padding: 8px 14px;
    border-radius: 24px;
    font-size: 0.7rem;
    font-weight: 700;
    z-index: 10;
    display: flex;
    align-items: center;
    gap: 6px;
    box-shadow: 0 4px 15px rgba(196, 30, 58, 0.4);
    text-transform: uppercase;
    letter-spacing: 0.5px;
    transition: all 0.3s ease;
  }

  .newsletter-card:hover .newsletter-badge {
    transform: translateY(-4px);
    box-shadow: 0 8px 25px rgba(196, 30, 58, 0.5);
  }

  .newsletter-image-wrapper {
    position: relative;
    width: 100%;
    height: 240px;
    overflow: hidden;
  }

  .newsletter-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.5s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .newsletter-card:hover .newsletter-img {
    transform: scale(1.12);
  }

  .newsletter-overlay {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: linear-gradient(180deg, rgba(0,0,0,0.1) 0%, rgba(0,0,0,0.3) 100%);
    transition: background 0.4s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .newsletter-card:hover .newsletter-overlay {
    background: linear-gradient(180deg, rgba(255, 193, 7, 0.2) 0%, rgba(255, 193, 7, 0.35) 100%);
  }

  .newsletter-content {
    padding: 28px;
    flex-grow: 1;
    display: flex;
    flex-direction: column;
  }

  .newsletter-title {
    font-size: 1.3rem;
    font-weight: 800;
    color: #1a1a2e;
    margin-bottom: 14px;
    line-height: 1.4;
    letter-spacing: -0.5px;
    transition: color 0.3s ease;
  }

  .newsletter-card:hover .newsletter-title {
    color: #c41e3a;
  }

  .newsletter-date {
    font-size: 0.85rem;
    color: #c41e3a;
    margin-bottom: 16px;
    display: flex;
    align-items: center;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.5px;
  }

  .newsletter-description {
    color: #6b7280;
    font-size: 0.95rem;
    line-height: 1.7;
    margin-bottom: 20px;
    flex-grow: 1;
  }

  .btn-read-newsletter {
    display: inline-flex;
    align-items: center;
    color: #ffc107;
    text-decoration: none;
    font-weight: 700;
    font-size: 0.95rem;
    transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    text-transform: uppercase;
    letter-spacing: 0.5px;
    position: relative;
  }

  .btn-read-newsletter::after {
    content: '';
    position: absolute;
    bottom: -3px;
    left: 0;
    width: 0;
    height: 2px;
    background: #ffc107;
    transition: width 0.3s ease;
  }

  .btn-read-newsletter:hover {
    color: #c41e3a;
  }

  .btn-read-newsletter:hover::after {
    width: 100%;
    background: #c41e3a;
  }

  .btn-read-newsletter i {
    transition: transform 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    margin-left: 8px;
  }

  .btn-read-newsletter:hover i {
    transform: translateX(6px);
  }
</style>
</style>
