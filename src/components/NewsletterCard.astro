---
export interface Props {
  newsletter: any;
}

const { newsletter } = Astro.props;
const { frontmatter } = newsletter;

const getPreview = () => {
  if (frontmatter.description) {
    return frontmatter.description.split(' ').slice(0, 30).join(' ');
  }
  return '';
};

const getSlug = () => {
  const filePath = (newsletter as any).file || '';
  const fileName = filePath.split(/[\/\\]/).pop() || '';
  const slug = fileName.replace('.md', '').trim();
  if (slug) return slug;
  return frontmatter.title?.toLowerCase().replace(/\s+/g, '-') || 'newsletter';
};

const preview = getPreview();
const slug = getSlug();
---

<div class="newsletter-card h-100">
  <div class="newsletter-badge">
    <i class="fas fa-envelope"></i> Newsletter
  </div>
  
  <div class="newsletter-image-wrapper">
    {frontmatter.image && (
      <img src={frontmatter.image} class="newsletter-img" alt={frontmatter.title}>
    )}
    <div class="newsletter-overlay"></div>
  </div>
  
  <div class="newsletter-content">
    <h5 class="newsletter-title">{frontmatter.title}</h5>
    
    {frontmatter.date && (
      <p class="newsletter-date">
        <i class="fas fa-calendar-alt me-2"></i>
        {new Date(frontmatter.date).toLocaleDateString('en-US', { 
          year: 'numeric', 
          month: 'long', 
          day: 'numeric' 
        })}
      </p>
    )}
    
    <p class="newsletter-description">{preview}{preview && '...'}</p>
    
    <a href={`/newsletter/${slug}`} class="btn-read-newsletter">
      Read Latest <i class="fas fa-arrow-right ms-2"></i>
    </a>
  </div>
</div>

<style>
  .newsletter-card {
    border: none;
    border-radius: 12px;
    overflow: hidden;
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.12);
    transition: all 0.3s ease;
    background: white;
    display: flex;
    flex-direction: column;
    position: relative;
  }

  .newsletter-card:hover {
    transform: translateY(-12px);
    box-shadow: 0 16px 40px rgba(255, 193, 7, 0.2);
  }

  .newsletter-badge {
    position: absolute;
    top: 12px;
    left: 12px;
    background: linear-gradient(135deg, #c41e3a, #a01830);
    color: white;
    padding: 6px 12px;
    border-radius: 20px;
    font-size: 0.75rem;
    font-weight: 600;
    z-index: 10;
    display: flex;
    align-items: center;
    gap: 6px;
    box-shadow: 0 4px 12px rgba(196, 30, 58, 0.3);
  }

  .newsletter-image-wrapper {
    position: relative;
    width: 100%;
    height: 220px;
    overflow: hidden;
  }

  .newsletter-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.3s ease;
  }

  .newsletter-card:hover .newsletter-img {
    transform: scale(1.08);
  }

  .newsletter-overlay {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: linear-gradient(180deg, rgba(0,0,0,0) 0%, rgba(0,0,0,0.2) 100%);
    transition: background 0.3s ease;
  }

  .newsletter-card:hover .newsletter-overlay {
    background: linear-gradient(180deg, rgba(255, 193, 7, 0.15) 0%, rgba(255, 193, 7, 0.25) 100%);
  }

  .newsletter-content {
    padding: 24px;
    flex-grow: 1;
    display: flex;
    flex-direction: column;
  }

  .newsletter-title {
    font-size: 1.25rem;
    font-weight: 700;
    color: #1a1a2e;
    margin-bottom: 12px;
    line-height: 1.3;
  }

  .newsletter-date {
    font-size: 0.85rem;
    color: #c41e3a;
    margin-bottom: 12px;
    display: flex;
    align-items: center;
  }

  .newsletter-description {
    color: #666;
    font-size: 0.95rem;
    line-height: 1.6;
    margin-bottom: 16px;
    flex-grow: 1;
  }

  .btn-read-newsletter {
    display: inline-flex;
    align-items: center;
    color: #ffc107;
    text-decoration: none;
    font-weight: 600;
    font-size: 0.95rem;
    transition: all 0.3s ease;
  }

  .btn-read-newsletter:hover {
    color: #c41e3a;
  }

  .btn-read-newsletter i {
    transition: transform 0.3s ease;
  }

  .btn-read-newsletter:hover i {
    transform: translateX(4px);
  }
</style>
