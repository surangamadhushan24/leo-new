---
export interface Props {
  project: any;
}

const { project } = Astro.props;
const { frontmatter } = project;

const getPreview = () => {
  if (frontmatter.description) {
    return frontmatter.description.split(' ').slice(0, 30).join(' ');
  }
  return '';
};

const getSlug = () => {
  const filePath = (project as any).file || '';
  const fileName = filePath.split(/[\/\\]/).pop() || '';
  const slug = fileName.replace('.md', '').trim();
  if (slug) return slug;
  return frontmatter.title?.toLowerCase().replace(/\s+/g, '-') || 'project';
};

const preview = getPreview();
const slug = getSlug();
---

<div class="project-card h-100">
  <div class="project-hero">
    {frontmatter.image ? (
      <img src={frontmatter.image} class="project-image" alt={frontmatter.title} />
    ) : (
      <div class="project-image project-image-fallback"></div>
    )}
    <div class="project-hero-overlay"></div>
    {frontmatter.category && <span class="project-category">{frontmatter.category}</span>}
    {frontmatter.date && (
      <span class="project-date-pill">
        <i class="fas fa-calendar-alt"></i>
        {new Date(frontmatter.date).toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' })}
      </span>
    )}
  </div>

  <div class="project-info">
    <h5 class="project-title">{frontmatter.title}</h5>
    <p class="project-description">{preview}{preview && '...'}</p>
    <div class="project-footer">
      <a href={`/projects/${slug}`} class="project-cta">
        Explore Project <i class="fas fa-arrow-right"></i>
      </a>
    </div>
  </div>
</div>

<style>
  .project-card {
    border: none;
    border-radius: 24px;
    overflow: hidden;
    background: white;
    display: flex;
    flex-direction: column;
    min-height: 100%;
    box-shadow: 0 18px 45px rgba(15, 23, 42, 0.08);
    transition: transform 0.4s ease, box-shadow 0.4s ease;
    position: relative;
  }

  .project-card:hover {
    transform: translateY(-14px);
    box-shadow: 0 26px 60px rgba(15, 23, 42, 0.14);
  }

  .project-hero {
    position: relative;
    height: 260px;
    overflow: hidden;
    background: #f3f4f6;
  }

  .project-image,
  .project-image-fallback {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .project-image-fallback {
    background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  }

  .project-card:hover .project-image {
    transform: scale(1.08);
  }

  .project-hero-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(180deg, rgba(15, 23, 42, 0.08) 0%, rgba(15, 23, 42, 0.32) 100%);
  }

  .project-category {
    position: absolute;
    top: 18px;
    left: 18px;
    background: rgba(255, 255, 255, 0.95);
    color: #111827;
    padding: 10px 18px;
    border-radius: 999px;
    font-size: 0.75rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    box-shadow: 0 15px 40px rgba(15, 23, 42, 0.08);
  }

  .project-date-pill {
    position: absolute;
    bottom: 18px;
    left: 18px;
    background: rgba(255, 255, 255, 0.95);
    color: #1f2937;
    padding: 10px 16px;
    border-radius: 14px;
    font-size: 0.8rem;
    font-weight: 600;
    display: inline-flex;
    align-items: center;
    gap: 8px;
    box-shadow: 0 15px 40px rgba(15, 23, 42, 0.1);
  }

  .project-info {
    padding: 32px;
    display: flex;
    flex-direction: column;
    gap: 22px;
    flex-grow: 1;
  }

  .project-title {
    font-size: 1.45rem;
    font-weight: 800;
    color: #111827;
    margin: 0;
    line-height: 1.25;
    letter-spacing: -0.5px;
  }

  .project-description {
    color: #4b5563;
    font-size: 1rem;
    line-height: 1.8;
    margin: 0;
    flex-grow: 1;
  }

  .project-footer {
    display: flex;
    align-items: center;
    justify-content: flex-start;
  }

  .project-cta {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 10px;
    padding: 14px 22px;
    border-radius: 16px;
    background: linear-gradient(135deg, #ffc107, #ffb300);
    color: #1f2937;
    font-weight: 700;
    text-decoration: none;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    box-shadow: 0 12px 24px rgba(255, 193, 7, 0.18);
    transition: transform 0.3s ease, box-shadow 0.3s ease;
  }

  .project-cta:hover {
    transform: translateY(-2px);
    box-shadow: 0 18px 32px rgba(255, 193, 7, 0.25);
  }
</style>