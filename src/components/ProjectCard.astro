---
export interface Props {
  project: any;
}

const { project } = Astro.props;
const { frontmatter } = project;

// Extract preview text from description or body
const getPreview = () => {
  if (frontmatter.description) {
    return frontmatter.description.split(' ').slice(0, 30).join(' ');
  }
  return '';
};

// Get slug from file name or frontmatter
const getSlug = () => {
  const filePath = (project as any).file || '';
  const fileName = filePath.split(/[\/\\]/).pop() || '';
  const slug = fileName.replace('.md', '').trim();
  if (slug) return slug;
  return frontmatter.title?.toLowerCase().replace(/\s+/g, '-') || 'project';
};

const preview = getPreview();
const slug = getSlug();
---

<div class="project-card h-100">
  <div class="card-image-wrapper">
    {frontmatter.image && (
      <img src={frontmatter.image} class="card-img" alt={frontmatter.title}>
    )}
    <div class="card-overlay"></div>
    {frontmatter.category && (
      <span class="category-badge">{frontmatter.category}</span>
    )}
  </div>
  <div class="card-content">
    <h5 class="card-title">{frontmatter.title}</h5>
    {frontmatter.date && (
      <p class="card-date">
        <i class="fas fa-calendar-alt me-2"></i>
        {new Date(frontmatter.date).toLocaleDateString('en-US', { 
          year: 'numeric', 
          month: 'short', 
          day: 'numeric' 
        })}
      </p>
    )}
    <p class="card-description">{preview}{preview && '...'}</p>
    <a href={`/projects/${slug}`} class="btn-read-more">
      Read More <i class="fas fa-arrow-right ms-2"></i>
    </a>
  </div>
</div>

<style>
  .project-card {
    border: none;
    border-radius: 16px;
    overflow: hidden;
    box-shadow: 0 10px 30px rgba(0, 0, 0, 0.12);
    transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
    background: white;
    display: flex;
    flex-direction: column;
    position: relative;
  }

  .project-card::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 4px;
    background: linear-gradient(to right, #ffc107, #c41e3a);
    transform: scaleX(0);
    transition: transform 0.4s cubic-bezier(0.4, 0, 0.2, 1);
    transform-origin: left;
    z-index: 10;
  }

  .project-card:hover::before {
    transform: scaleX(1);
  }

  .project-card:hover {
    transform: translateY(-16px);
    box-shadow: 0 20px 50px rgba(196, 30, 58, 0.2);
  }

  .card-image-wrapper {
    position: relative;
    width: 100%;
    height: 240px;
    overflow: hidden;
  }

  .card-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.5s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .project-card:hover .card-img {
    transform: scale(1.12);
  }

  .card-overlay {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: linear-gradient(180deg, rgba(0,0,0,0.1) 0%, rgba(0,0,0,0.3) 100%);
    transition: background 0.4s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .project-card:hover .card-overlay {
    background: linear-gradient(180deg, rgba(196, 30, 58, 0.25) 0%, rgba(196, 30, 58, 0.5) 100%);
  }

  .category-badge {
    position: absolute;
    top: 16px;
    right: 16px;
    background: linear-gradient(135deg, #ffc107, #ffb300);
    color: #1a1a2e;
    padding: 8px 16px;
    border-radius: 24px;
    font-size: 0.7rem;
    font-weight: 700;
    box-shadow: 0 4px 15px rgba(255, 193, 7, 0.4);
    text-transform: uppercase;
    letter-spacing: 0.5px;
    transition: all 0.3s ease;
  }

  .project-card:hover .category-badge {
    transform: translateY(-4px);
    box-shadow: 0 8px 25px rgba(255, 193, 7, 0.5);
  }

  .card-content {
    padding: 28px;
    flex-grow: 1;
    display: flex;
    flex-direction: column;
  }

  .card-title {
    font-size: 1.3rem;
    font-weight: 800;
    color: #1a1a2e;
    margin-bottom: 14px;
    line-height: 1.4;
    letter-spacing: -0.5px;
    transition: color 0.3s ease;
  }

  .project-card:hover .card-title {
    color: #c41e3a;
  }

  .card-date {
    font-size: 0.85rem;
    color: #c41e3a;
    margin-bottom: 16px;
    display: flex;
    align-items: center;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.5px;
  }

  .card-description {
    color: #6b7280;
    font-size: 0.95rem;
    line-height: 1.7;
    margin-bottom: 20px;
    flex-grow: 1;
  }

  .btn-read-more {
    display: inline-flex;
    align-items: center;
    color: #ffc107;
    text-decoration: none;
    font-weight: 700;
    font-size: 0.95rem;
    transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    text-transform: uppercase;
    letter-spacing: 0.5px;
    position: relative;
  }

  .btn-read-more::after {
    content: '';
    position: absolute;
    bottom: -3px;
    left: 0;
    width: 0;
    height: 2px;
    background: #ffc107;
    transition: width 0.3s ease;
  }

  .btn-read-more:hover {
    color: #c41e3a;
  }

  .btn-read-more:hover::after {
    width: 100%;
    background: #c41e3a;
  }

  .btn-read-more i {
    transition: transform 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    margin-left: 8px;
  }

  .btn-read-more:hover i {
    transform: translateX(6px);
  }
</style>