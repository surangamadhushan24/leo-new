---
// Hero Carousel Component - Fixed version
---

<div id="heroCarousel" class="carousel slide" data-bs-ride="carousel">
  <div class="carousel-indicators">
    <button type="button" data-bs-target="#heroCarousel" data-bs-slide-to="0" class="active"></button>
    <button type="button" data-bs-target="#heroCarousel" data-bs-slide-to="1"></button>
    <button type="button" data-bs-target="#heroCarousel" data-bs-slide-to="2"></button>
  </div>
  
  <div class="carousel-inner">
    <div class="carousel-item active">
      <img src="/images/hero-1.jpg" class="d-block w-100" alt="Leadership Through Service" style="height: 90vh; object-fit: cover;">
      <div class="carousel-caption d-flex flex-column justify-content-center h-100">
        <h5 class="text-uppercase fw-bold mb-4" style="letter-spacing: 3px;">WE'll Serve Our Community</h5>
        <h1 class="display-3 mb-4">Leadership Through Service</h1>
        <p class="mb-5 fs-5">Join us in making a difference in Baddegama and beyond</p>
        <div>
          <a href="/join" class="btn btn-warning px-5 py-3">Join With Us</a>
        </div>
      </div>
    </div>
    
    <div class="carousel-item">
      <img src="/images/hero-2.jpg" class="d-block w-100" alt="Community Projects" style="height: 90vh; object-fit: cover;">
      <div class="carousel-caption d-flex flex-column justify-content-center h-100">
        <h5 class="text-uppercase fw-bold mb-4" style="letter-spacing: 3px;">WE'll Make An Impact</h5>
        <h1 class="display-3 mb-4">Community Projects</h1>
        <p class="mb-5 fs-5">Discover how we're transforming lives through our initiatives</p>
        <div>
          <a href="/projects" class="btn btn-warning px-5 py-3">Our Projects</a>
        </div>
      </div>
    </div>
    
    <div class="carousel-item">
      <img src="/images/hero-3.jpg" class="d-block w-100" alt="Join Our Family" style="height: 90vh; object-fit: cover;">
      <div class="carousel-caption d-flex flex-column justify-content-center h-100">
        <h5 class="text-uppercase fw-bold mb-4" style="letter-spacing: 3px;">WE'll Build Friendships</h5>
        <h1 class="display-3 mb-4">Join Our Family</h1>
        <p class="mb-5 fs-5">Experience leadership, friendship and personal growth</p>
        <div>
          <a href="/about" class="btn btn-warning px-5 py-3">Learn More</a>
        </div>
      </div>
    </div>
  </div>
  
  <button class="carousel-control-prev" type="button" data-bs-target="#heroCarousel" data-bs-slide="prev">
    <span class="carousel-control-prev-icon"></span>
  </button>
  <button class="carousel-control-next" type="button" data-bs-target="#heroCarousel" data-bs-slide="next">
    <span class="carousel-control-next-icon"></span>
  </button>
</div>

<script>
  // Initialize carousel using global Bootstrap loaded from CDN
  document.addEventListener('DOMContentLoaded', () => {
    const carouselElement = document.querySelector('#heroCarousel');
    if (carouselElement && (window as any).bootstrap) {
      const carousel = new (window as any).bootstrap.Carousel(carouselElement, {
        interval: 5000,
        wrap: true
      });
    }
  });
</script>