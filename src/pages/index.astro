---
import Layout from '../layouts/Layout.astro';
import HeroCarousel from '../components/HeroCarousel.astro';
import Counter from '../components/Counter.astro';
import ProjectCard from '../components/ProjectCard.astro';
import EventCard from '../components/EventCard.astro';
import NewsletterCard from '../components/NewsletterCard.astro';
import ExecutiveCommitteeCarousel from '../components/ExecutiveCommitteeCarousel.astro';

// Fetch content
let projects: any[] = [];
let events: any[] = [];
let newsletters: any[] = [];
let committeeMembers: any[] = [];

try {
  projects = await Astro.glob('../content/projects/*.md');
} catch (e) {
  projects = [];
}

try {
  events = await Astro.glob('../content/events/*.md');
} catch (e) {
  events = [];
}

try {
  newsletters = await Astro.glob('../content/newsletter/*.md');
} catch (e) {
  newsletters = [];
}

try {
  const committeeModules = import.meta.glob('../content/committee/*.md');
  const committeePaths = Object.keys(committeeModules);
  committeeMembers = await Promise.all(
    committeePaths.map(async (path) => {
      const module = await committeeModules[path]();
      return { ...(module as any), file: path };
    })
  );
} catch (e) {
  committeeMembers = [];
}

// Sort committee members by file name to maintain order
const sortedCommittee = committeeMembers.sort((a, b) => {
  const fileA = (a as any).file || '';
  const fileB = (b as any).file || '';
  return fileA.localeCompare(fileB);
});
const visibleCommittee = sortedCommittee.slice(0, 6);
const latestProjects = projects
  .sort((a, b) => {
    const dateA = new Date(a.frontmatter.date || 0);
    const dateB = new Date(b.frontmatter.date || 0);
    return dateB.getTime() - dateA.getTime();
  })
  .slice(0, 3);

const upcomingEvents = events
  .filter(event => {
    const eventDate = new Date(event.frontmatter.date || 0);
    return eventDate >= new Date();
  })
  .sort((a, b) => {
    const dateA = new Date(a.frontmatter.date || 0);
    const dateB = new Date(b.frontmatter.date || 0);
    return dateA.getTime() - dateB.getTime();
  })
  .slice(0, 3);

const latestNewsletters = newsletters
  .sort((a, b) => {
    const dateA = new Date(a.frontmatter.date || 0);
    const dateB = new Date(b.frontmatter.date || 0);
    return dateB.getTime() - dateA.getTime();
  })
  .slice(0, 3);
---

<Layout title="Home" description="Leo Club of Baddegama - Leadership through service">
  <!-- Hero Section -->
  <section id="home">
    <HeroCarousel />
  </section>

  <!-- About Section -->
  <section id="about" class="py-5 position-relative overflow-hidden" style="background: linear-gradient(135deg, var(--light-bg) 0%, rgba(255,193,7,0.05) 50%, var(--lighter-bg) 100%);">
    <!-- Background Pattern -->
    <div class="position-absolute top-0 start-0 w-100 h-100 opacity-25" style="background-image: radial-gradient(circle at 25% 25%, rgba(255,193,7,0.1) 0%, transparent 50%), radial-gradient(circle at 75% 75%, rgba(196,30,58,0.1) 0%, transparent 50%);"></div>

    <div class="container py-5 position-relative">
      <div class="row align-items-center">
        <!-- Image Column -->
        <div class="col-lg-6 mb-4 mb-lg-0">
          <div class="position-relative">
            <div class="about-image-container">
              <img src="/images/logo.png" alt="About BG Leos" class="img-fluid rounded-4 shadow-lg about-image">
              <!-- Decorative Elements -->
              <div class="position-absolute top-0 start-0 translate-middle">
                <div class="decorative-circle bg-gradient-primary opacity-75"></div>
              </div>
              <div class="position-absolute bottom-0 end-0 translate-middle">
                <div class="decorative-circle bg-gradient-accent opacity-75"></div>
              </div>
            </div>
          </div>
        </div>

        <!-- Content Column -->
        <div class="col-lg-6">
          <div class="about-content">
            <div class="mb-4">
              <span class="badge badge-primary mb-3 d-inline-block">About Us</span>
              <h2 class="section-title text-start mb-4" style="margin-bottom: 2rem !important;">About BG Leos</h2>
            </div>

            <p class="lead text-secondary mb-4 fs-5 lh-base">
              We are a dynamic group of young leaders committed to making a positive impact in our community through service, leadership, and friendship.
            </p>

            <p class="text-muted mb-4 fs-6 lh-base">
              The Leo Club of Baddegama is part of the international Leo movement, providing young people with opportunities for development and contributions to society. We believe in the power of collective action to create lasting change.
            </p>

            <!-- Feature List -->
            <div class="row g-3 mb-4">
              <div class="col-md-6">
                <div class="feature-item d-flex align-items-center p-3 rounded-3 bg-white shadow-sm transition-all">
                  <div class="feature-icon me-3">
                    <i class="fas fa-hand-holding-heart text-warning fs-4"></i>
                  </div>
                  <div>
                    <h6 class="mb-0 fw-bold text-secondary">Community Service</h6>
                    <small class="text-muted">Making a difference together</small>
                  </div>
                </div>
              </div>
              <div class="col-md-6">
                <div class="feature-item d-flex align-items-center p-3 rounded-3 bg-white shadow-sm transition-all">
                  <div class="feature-icon me-3">
                    <i class="fas fa-users text-warning fs-4"></i>
                  </div>
                  <div>
                    <h6 class="mb-0 fw-bold text-secondary">Leadership Development</h6>
                    <small class="text-muted">Growing future leaders</small>
                  </div>
                </div>
              </div>
              <div class="col-md-6">
                <div class="feature-item d-flex align-items-center p-3 rounded-3 bg-white shadow-sm transition-all">
                  <div class="feature-icon me-3">
                    <i class="fas fa-network-wired text-warning fs-4"></i>
                  </div>
                  <div>
                    <h6 class="mb-0 fw-bold text-secondary">Networking</h6>
                    <small class="text-muted">Building connections</small>
                  </div>
                </div>
              </div>
              <div class="col-md-6">
                <div class="feature-item d-flex align-items-center p-3 rounded-3 bg-white shadow-sm transition-all">
                  <div class="feature-icon me-3">
                    <i class="fas fa-seedling text-warning fs-4"></i>
                  </div>
                  <div>
                    <h6 class="mb-0 fw-bold text-secondary">Personal Growth</h6>
                    <small class="text-muted">Continuous development</small>
                  </div>
                </div>
              </div>
            </div>

            <!-- CTA Button -->
            <div class="d-flex gap-3 flex-wrap">
              <a href="/about" class="btn btn-warning btn-lg px-4 py-3 fw-bold">
                <i class="fas fa-info-circle me-2"></i>Learn More About Us
              </a>
              <a href="/join" class="btn btn-outline-primary btn-lg px-4 py-3 fw-bold">
                <i class="fas fa-user-plus me-2"></i>Join Our Community
              </a>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Counter Section -->
  <section style="background: linear-gradient(135deg, var(--secondary-color) 0%, #0f0f1e 100%); color: white; padding: 80px 0;">
    <div class="container">
      <div class="row text-center">
        <div class="col-md-3 col-6 mb-4">
          <div class="counter-item">
            <i class="fas fa-users fa-3x text-warning mb-3"></i>
            <div class="counter-value display-4 fw-bold mb-2">
              <Counter target={85} />
            </div>
            <div class="counter-text fs-5">Active Members</div>
          </div>
        </div>
        <div class="col-md-3 col-6 mb-4">
          <div class="counter-item">
            <i class="fas fa-hand-holding-heart fa-3x text-warning mb-3"></i>
            <div class="counter-value display-4 fw-bold mb-2">
              <Counter target={42} />
            </div>
            <div class="counter-text fs-5">Projects Completed</div>
          </div>
        </div>
        <div class="col-md-3 col-6 mb-4">
          <div class="counter-item">
            <i class="fas fa-calendar-check fa-3x text-warning mb-3"></i>
            <div class="counter-value display-4 fw-bold mb-2">
              <Counter target={36} />
            </div>
            <div class="counter-text fs-5">Events Organized</div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Recent Projects -->
  <section id="projects" class="py-5" style="background-color: var(--light-bg);">
    <div class="container py-5">
      <div class="row mb-5">
        <div class="col-12 text-center">
          <h2 class="section-title">Our Recent Projects</h2>
          <p class="lead text-secondary">Making a difference in our community through meaningful initiatives</p>
        </div>
      </div>
      
      <div class="row">
        {latestProjects.map(project => (
          <div class="col-lg-4 col-md-6 mb-4">
            <ProjectCard project={project} />
          </div>
        ))}
      </div>
      
      <div class="text-center mt-4">
        <a href="/projects" class="btn btn-warning btn-lg">View All Projects</a>
      </div>
    </div>
  </section>

  <!-- Upcoming Events -->
  <section id="events" class="py-5">
    <div class="container py-5">
      <div class="row mb-5">
        <div class="col-12 text-center">
          <h2 class="section-title">Upcoming Events</h2>
          <p class="lead">Join us in our upcoming activities and make a difference</p>
        </div>
      </div>
      
      <div class="row">
        {upcomingEvents.length > 0 ? (
          upcomingEvents.map(event => (
            <div class="col-lg-4 col-md-6 mb-4">
              <EventCard event={event} />
            </div>
          ))
        ) : (
          <div class="col-12 text-center">
            <p class="lead">No upcoming events at the moment. Check back soon!</p>
          </div>
        )}
      </div>
      
      <div class="text-center mt-4">
        <a href="/events" class="btn btn-warning btn-lg">View All Events</a>
      </div>
    </div>
  </section>

  <!-- Latest Newsletter -->
  <section id="newsletter" class="py-5" style="background-color: var(--light-bg);">
    <div class="container py-5">
      <div class="row mb-5">
        <div class="col-12 text-center">
          <h2 class="section-title">Latest Newsletter</h2>
          <p class="lead text-secondary">Stay informed with our latest news and community updates</p>
        </div>
      </div>
      
      <div class="row">
        {latestNewsletters.length > 0 ? (
          latestNewsletters.map(newsletter => (
            <div class="col-lg-4 col-md-6 mb-4">
              <NewsletterCard newsletter={newsletter} />
            </div>
          ))
        ) : (
          <div class="col-12 text-center">
            <p class="lead">No newsletters available yet. Check back soon!</p>
          </div>
        )}
      </div>
      
      <div class="text-center mt-4">
        <a href="/newsletter" class="btn btn-warning btn-lg">View More Newsletter</a>
      </div>
    </div>
  </section>


  <!-- Executive Committee 2025/26 -->
  <section id="committee" class="py-5" style="padding: 0; background: transparent; position: relative; overflow: hidden;">

      <div class="committee-grid-wrapper">
        {visibleCommittee.length > 0 ? (
          <ExecutiveCommitteeCarousel members={visibleCommittee} />
        ) : (
          <div class="text-center" style="padding: 60px 20px;">
            <div style="width: 80px; height: 80px; background: linear-gradient(135deg, #ffc107, #ffb300); border-radius: 50%; display: inline-flex; align-items: center; justify-content: center; margin-bottom: 20px; box-shadow: 0 8px 25px rgba(255, 193, 7, 0.3);">
              <i class="fas fa-users fa-2x" style="color: #1a1a2e;"></i>
            </div>
            <h4 style="color: #1a1a2e; font-weight: 700; margin-bottom: 10px;">Committee Coming Soon</h4>
            <p class="lead" style="color: #6b7280;">Our executive committee information will be available shortly.</p>
          </div>
        )}
      </div>

      <div class="text-center mt-5">
        <a href="/about" class="btn btn-warning btn-lg" style="font-weight: 700; text-transform: uppercase; letter-spacing: 0.5px; padding: 14px 32px; font-size: 1rem; box-shadow: 0 8px 25px rgba(255, 193, 7, 0.4); transition: all 0.3s ease;">
          Meet All Members
        </a>
      </div>
    </div>
  </section>

  <style is:inline>
    .committee-carousel-wrapper {
      margin-bottom: 40px;
    }
  </style>

</Layout>
