---
import Layout from '../layouts/Layout.astro';
import NewsletterCard from '../components/NewsletterCard.astro';

const newsletters = await Astro.glob('../content/newsletter/*.md');
const sortedNewsletters = newsletters.sort((a, b) => {
  const dateA = new Date(a.frontmatter.date || 0);
  const dateB = new Date(b.frontmatter.date || 0);
  return dateB.getTime() - dateA.getTime();
});
---

<Layout title="Newsletter — Leo Club of Baddegama" description="BG Leos Newsletter — latest news, updates and community stories from the Leo Club of Baddegama.">
  <!-- Hero Section -->
  <section class="hero-newsletter">
    <div class="container py-5 text-white">
      <div class="breadcrumb-custom mb-4">
        <a href="/" class="breadcrumb-item">Home</a>
        <span class="breadcrumb-divider">/</span>
        <span class="breadcrumb-item active">Newsletter</span>
      </div>
      <h1 class="newsletter-title mb-3">Newsletter</h1>
      <p class="newsletter-description mb-0">Stay updated with our latest news and community stories</p>
    </div>
  </section>

  <!-- Newsletters Grid -->
  <section class="py-5">
    <div class="container py-5">
      <div class="row mb-5">
        <div class="col-12 text-center">
          <h2 class="section-title">Latest Issues</h2>
          <p class="lead">Read our monthly newsletters packed with updates, stories, and opportunities</p>
        </div>
      </div>

      <div class="row">
        {sortedNewsletters.map(newsletter => (
          <div class="col-lg-4 col-md-6 mb-4">
            <NewsletterCard newsletter={newsletter} />
          </div>
        ))}
      </div>

      {sortedNewsletters.length === 0 && (
        <div class="row">
          <div class="col-12 text-center py-5">
            <p class="fs-5 text-muted">No newsletters available yet. Check back soon!</p>
          </div>
        </div>
      )}
    </div>
  </section>

  <!-- Subscribe Section -->
  <!-- <section class="py-5 bg-light">
    <div class="container py-5">
      <div class="row justify-content-center">
        <div class="col-lg-8">
          <div class="text-center mb-5">
            <h2 class="section-title">Don't Miss Out</h2>
            <p class="lead">Subscribe to get the latest newsletter directly to your inbox</p>
          </div>
          
          <form id="newsletterForm" class="needs-validation">
            <div class="row g-3">
              <div class="col-md-6">
                <label for="name" class="form-label fw-bold">Full Name</label>
                <input type="text" class="form-control" id="name" name="name" placeholder="Your name" required>
              </div>
              
              <div class="col-md-6">
                <label for="email" class="form-label fw-bold">Email Address</label>
                <input type="email" class="form-control" id="email" name="email" placeholder="your@email.com" required>
              </div>
            </div>

            <div class="form-check my-4">
              <input class="form-check-input" type="checkbox" id="agree" name="agree" required>
              <label class="form-check-label" for="agree">
                I agree to receive updates and newsletters from BG Leos
              </label>
            </div>

            <button type="submit" class="btn btn-warning btn-lg w-100 fw-bold">Subscribe Now</button>
          </form>
        </div>
      </div>
    </div>
  </section> -->
</Layout>

<style>
  .hero-newsletter {
    margin-top: -76px;
    padding-top: 150px;
    padding-bottom: 60px;
    background: linear-gradient(135deg, #1a1a2e 0%, #16213e 100%);
    color: white;
  }

  .breadcrumb-custom {
    display: flex;
    align-items: center;
    gap: 10px;
    margin-bottom: 30px;
    font-size: 0.95rem;
  }

  .breadcrumb-custom .breadcrumb-item {
    color: #ffc107;
    text-decoration: none;
    transition: color 0.3s ease;
  }

  .breadcrumb-custom .breadcrumb-item:hover {
    color: #fff;
  }

  .breadcrumb-custom .breadcrumb-item.active {
    color: #ffc107;
  }

  .breadcrumb-divider {
    color: rgba(255, 255, 255, 0.5);
  }

  .newsletter-title {
    font-size: 3rem;
    font-weight: 700;
    line-height: 1.2;
    color: #fff;
  }

  .newsletter-description {
    font-size: 1.2rem;
    color: rgba(255, 255, 255, 0.9);
  }

  @media (max-width: 992px) {
    .newsletter-title {
      font-size: 2rem;
    }
  }

  #newsletterForm {
    max-width: 600px;
    margin: 0 auto;
  }

  .section-title {
    font-size: 2.5rem;
    font-weight: bold;
    color: #1a1a1a;
    margin-bottom: 3rem;
  }
</style>
