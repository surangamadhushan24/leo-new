---
import Layout from '../../layouts/Layout.astro';

interface Event {
  file: string;
  frontmatter: {
    title: string;
    date: string;
    description: string;
    location?: string;
    time?: string;
    image?: string;
  };
  default: any;
}

export async function getStaticPaths(): Promise<any[]> {
  const events: any[] = await Astro.glob('../../content/events/*.md');
  
  return events.map((event: any) => {
    // Extract slug from file path - get the file name without .md extension
    const filePath = (event as any).file || '';
    // Split by forward or backslash and get the last part
    const fileName = filePath.split(/[\/\\]/).pop() || '';
    const slug = fileName.replace('.md', '').trim();
    
    return {
      params: { slug },
      props: { event }
    };
  });
}

interface Props {
  event: any;
}

const { event } = Astro.props;
const { Content, frontmatter } = event;

const date = new Date(frontmatter.date);
const formattedDate = date.toLocaleDateString('en-US', { 
  year: 'numeric', 
  month: 'long', 
  day: 'numeric' 
});

const formattedTime = date.toLocaleTimeString('en-US', { 
  hour: '2-digit', 
  minute: '2-digit' 
});
---

<Layout title={frontmatter.title} description={frontmatter.description}>
  <style>
    .event-hero {
      position: relative;
      overflow: hidden;
      margin-top: -76px;
      padding-top: 120px;
      padding-bottom: 60px;
      background: linear-gradient(135deg, #1a1a2e 0%, #16213e 100%);
      color: white;
    }

    .event-hero::before {
      content: '';
      position: absolute;
      top: 0;
      right: 0;
      width: 40%;
      height: 100%;
      background: url('data:image/svg+xml,<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 1200 800"><defs><pattern id="dots" x="0" y="0" width="100" height="100" patternUnits="userSpaceOnUse"><circle cx="50" cy="50" r="3" fill="rgba(255,193,7,0.1)"/></pattern></defs><rect width="1200" height="800" fill="url(%23dots)"/></svg>');
      opacity: 0.3;
      pointer-events: none;
    }

    .event-hero-content {
      position: relative;
      z-index: 1;
    }

    .event-title {
      font-size: 3rem;
      font-weight: 700;
      margin-bottom: 20px;
      line-height: 1.2;
      color: #fff;
    }

    .event-description {
      font-size: 1.2rem;
      color: rgba(255, 255, 255, 0.9);
      margin-bottom: 0;
      max-width: 600px;
    }

    .breadcrumb-custom {
      display: flex;
      align-items: center;
      gap: 10px;
      margin-bottom: 30px;
      font-size: 0.95rem;
    }

    .breadcrumb-custom a {
      color: #ffc107;
      text-decoration: none;
      transition: color 0.3s ease;
    }

    .breadcrumb-custom a:hover {
      color: #fff;
    }

    .breadcrumb-custom::before,
    .breadcrumb-custom ::after {
      color: rgba(255, 255, 255, 0.5);
    }

    .event-quick-info {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(150px, 1fr));
      gap: 20px;
      margin-top: 40px;
    }

    .quick-info-item {
      display: flex;
      align-items: center;
      gap: 12px;
      padding: 15px;
      background: rgba(255, 193, 7, 0.15);
      border-radius: 10px;
      border-left: 4px solid #ffc107;
    }

    .quick-info-item i {
      font-size: 1.5rem;
      color: #ffc107;
      width: 30px;
    }

    .quick-info-item-text {
      display: flex;
      flex-direction: column;
    }

    .quick-info-label {
      font-size: 0.75rem;
      color: rgba(255, 255, 255, 0.7);
      text-transform: uppercase;
      letter-spacing: 0.5px;
    }

    .quick-info-value {
      font-weight: 600;
      color: #fff;
      font-size: 0.95rem;
    }

    /* Main Content Area */
    .event-content-wrapper {
      display: grid;
      grid-template-columns: 1fr 320px;
      gap: 40px;
      margin-top: -60px;
      position: relative;
      z-index: 2;
    }

    @media (max-width: 992px) {
      .event-content-wrapper {
        grid-template-columns: 1fr;
      }
      .event-title {
        font-size: 2rem;
      }
    }

    .featured-image-container {
      margin-bottom: 40px;
    }

    .featured-image {
      width: 100%;
      height: auto;
      border-radius: 12px;
      box-shadow: 0 10px 30px rgba(0, 0, 0, 0.15);
      object-fit: cover;
      transition: transform 0.3s ease;
    }

    .featured-image:hover {
      transform: scale(1.02);
    }

    .event-main-content {
      background: white;
      padding: 40px;
      border-radius: 12px;
      box-shadow: 0 5px 20px rgba(0, 0, 0, 0.08);
    }

    .event-main-content h2 {
      color: #1a1a2e;
      font-size: 1.8rem;
      margin-top: 30px;
      margin-bottom: 15px;
      border-bottom: 3px solid #ffc107;
      padding-bottom: 10px;
    }

    .event-main-content h2:first-child {
      margin-top: 0;
    }

    .event-main-content h3 {
      color: #16213e;
      font-size: 1.3rem;
      margin-top: 20px;
      margin-bottom: 12px;
    }

    .event-main-content ul {
      list-style: none;
      padding: 0;
    }

    .event-main-content li {
      padding: 8px 0;
      padding-left: 30px;
      position: relative;
      color: #555;
      line-height: 1.7;
    }

    .event-main-content li::before {
      content: '▸';
      position: absolute;
      left: 0;
      color: #ffc107;
      font-weight: bold;
      font-size: 1.2rem;
    }

    .event-main-content p {
      color: #555;
      line-height: 1.8;
      margin-bottom: 15px;
    }

    .event-main-content strong {
      color: #1a1a2e;
      font-weight: 600;
    }

    /* Sidebar */
    .event-sidebar {
      display: flex;
      flex-direction: column;
      gap: 20px;
    }

    .sidebar-card {
      background: white;
      padding: 25px;
      border-radius: 12px;
      box-shadow: 0 5px 20px rgba(0, 0, 0, 0.08);
      transition: transform 0.3s ease, box-shadow 0.3s ease;
    }

    .sidebar-card:hover {
      transform: translateY(-4px);
      box-shadow: 0 10px 30px rgba(0, 0, 0, 0.12);
    }

    .sidebar-card-title {
      font-size: 1.1rem;
      font-weight: 700;
      color: #1a1a2e;
      margin-bottom: 15px;
      display: flex;
      align-items: center;
      gap: 10px;
    }

    .sidebar-card-title i {
      color: #ffc107;
      font-size: 1.3rem;
    }

    .sidebar-detail {
      margin-bottom: 15px;
      display: flex;
      align-items: flex-start;
      gap: 12px;
    }

    .sidebar-detail:last-child {
      margin-bottom: 0;
    }

    .sidebar-detail i {
      color: #ffc107;
      margin-top: 3px;
      min-width: 20px;
    }

    .sidebar-detail-text {
      display: flex;
      flex-direction: column;
      gap: 3px;
    }

    .sidebar-detail-label {
      font-size: 0.8rem;
      color: #888;
      text-transform: uppercase;
      letter-spacing: 0.5px;
      font-weight: 600;
    }

    .sidebar-detail-value {
      color: #1a1a2e;
      font-weight: 500;
    }

    .cta-button {
      background: linear-gradient(135deg, #ffc107 0%, #ffb600 100%);
      color: #1a1a2e;
      border: none;
      padding: 14px 24px;
      border-radius: 8px;
      font-weight: 700;
      font-size: 1rem;
      cursor: pointer;
      transition: all 0.3s ease;
      width: 100%;
      text-align: center;
      text-decoration: none;
      display: block;
      box-shadow: 0 4px 15px rgba(255, 193, 7, 0.3);
    }

    .cta-button:hover {
      transform: translateY(-2px);
      box-shadow: 0 6px 20px rgba(255, 193, 7, 0.4);
      background: linear-gradient(135deg, #ffb600 0%, #ffa500 100%);
    }

    .secondary-button {
      background: #f0f0f0;
      color: #1a1a2e;
      border: 2px solid #e0e0e0;
      padding: 12px 20px;
      border-radius: 8px;
      font-weight: 600;
      cursor: pointer;
      transition: all 0.3s ease;
      width: 100%;
      text-align: center;
      text-decoration: none;
      display: block;
    }

    .secondary-button:hover {
      background: #e8e8e8;
      border-color: #ffc107;
    }

    .back-link {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      color: #ffc107;
      text-decoration: none;
      margin-bottom: 30px;
      font-weight: 600;
      transition: gap 0.3s ease;
    }

    .back-link:hover {
      gap: 12px;
      color: #ffb600;
    }

    .back-link i {
      font-size: 1.1rem;
    }
  </style>

  <!-- Hero Section -->
  <section class="event-hero">
    <div class="container">
      <div class="event-hero-content">
        <div class="breadcrumb-custom">
          <a href="/events"><i class="fas fa-home"></i> Events</a>
          <span style="color: rgba(255, 255, 255, 0.5);">/</span>
          <span style="color: #ffc107;">{frontmatter.title}</span>
        </div>
        <h1 class="event-title">{frontmatter.title}</h1>
        <p class="event-description">{frontmatter.description}</p>
        
        <div class="event-quick-info">
          {frontmatter.date && (
            <div class="quick-info-item">
              <i class="fas fa-calendar-alt"></i>
              <div class="quick-info-item-text">
                <span class="quick-info-label">Date</span>
                <span class="quick-info-value">{formattedDate}</span>
              </div>
            </div>
          )}
          {frontmatter.time && (
            <div class="quick-info-item">
              <i class="fas fa-clock"></i>
              <div class="quick-info-item-text">
                <span class="quick-info-label">Time</span>
                <span class="quick-info-value">{frontmatter.time}</span>
              </div>
            </div>
          )}
          {frontmatter.location && (
            <div class="quick-info-item">
              <i class="fas fa-map-marker-alt"></i>
              <div class="quick-info-item-text">
                <span class="quick-info-label">Location</span>
                <span class="quick-info-value">{frontmatter.location}</span>
              </div>
            </div>
          )}
        </div>
      </div>
    </div>
  </section>

  <!-- Content Section -->
  <section style="padding: 60px 0 80px;">
    <div class="container">
      <div class="event-content-wrapper">
        <div>
          {frontmatter.image && (
            <div class="featured-image-container">
              <img src={frontmatter.image} alt={frontmatter.title} class="featured-image">
            </div>
          )}
          
          <div class="event-main-content">
            <article class="event-content">
              <Content />
            </article>
          </div>
          
          <div class="back-link" style="margin-top: 30px;">
            <a href="/events" style="color: #ffc107; text-decoration: none; display: inline-flex; align-items: center; gap: 8px; font-weight: 600;">
              <i class="fas fa-arrow-left"></i>
              Back to Events
            </a>
          </div>
        </div>

        <!-- Sidebar -->
        <div class="event-sidebar">
          <!-- Event Details Card -->
          {(frontmatter.location || frontmatter.time) && (
            <div class="sidebar-card">
              <div class="sidebar-card-title">
                <i class="fas fa-info-circle"></i>
                Event Details
              </div>
              {frontmatter.date && (
                <div class="sidebar-detail">
                  <i class="fas fa-calendar"></i>
                  <div class="sidebar-detail-text">
                    <span class="sidebar-detail-label">Date</span>
                    <span class="sidebar-detail-value">{formattedDate}</span>
                  </div>
                </div>
              )}
              {frontmatter.time && (
                <div class="sidebar-detail">
                  <i class="fas fa-clock"></i>
                  <div class="sidebar-detail-text">
                    <span class="sidebar-detail-label">Time</span>
                    <span class="sidebar-detail-value">{frontmatter.time}</span>
                  </div>
                </div>
              )}
              {frontmatter.location && (
                <div class="sidebar-detail">
                  <i class="fas fa-map-marker-alt"></i>
                  <div class="sidebar-detail-text">
                    <span class="sidebar-detail-label">Location</span>
                    <span class="sidebar-detail-value">{frontmatter.location}</span>
                  </div>
                </div>
              )}
            </div>
          )}

          <!-- Call to Action Card -->
          <div class="sidebar-card">
            <div class="sidebar-card-title">
              <i class="fas fa-star"></i>
              Get Involved
            </div>
            <p style="color: #666; margin-bottom: 15px; font-size: 0.95rem;">
              Join us at this exciting Leo Club event and make a difference in our community!
            </p>
            <button class="cta-button" onclick="document.location='mailto:contact@leobaddegama.com?subject=Event Registration: {frontmatter.title}'">
              <i class="fas fa-envelope me-2"></i>Register Now
            </button>
          </div>

          <!-- Share Card -->
          <div class="sidebar-card">
            <div class="sidebar-card-title">
              <i class="fas fa-share-alt"></i>
              Share Event
            </div>
            <div style="display: flex; gap: 10px;">
              <button class="secondary-button" style="flex: 1; padding: 10px;" title="Share on Facebook">
                <i class="fab fa-facebook"></i>
              </button>
              <button class="secondary-button" style="flex: 1; padding: 10px;" title="Share on Twitter">
                <i class="fab fa-twitter"></i>
              </button>
              <button class="secondary-button" style="flex: 1; padding: 10px;" title="Share via Email">
                <i class="fas fa-envelope"></i>
              </button>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>
  </section>

  <!-- Navigation Links -->
  <section class="py-5 nav-section">
    <div class="container">
      <div class="row">
        <div class="col-12 text-center">
          <a href="/events" class="btn btn-warning btn-lg back-btn">
            <i class="fas fa-arrow-left me-2"></i>Back to Events
          </a>
        </div>
      </div>
    </div>
  </section>
</Layout>

<style>
  .breadcrumb-dark {
    background: none;
    padding: 0;
  }

  .breadcrumb-dark .breadcrumb-item {
    color: rgba(255, 255, 255, 0.7);
  }

  .breadcrumb-dark .breadcrumb-item a {
    color: #ffc107;
    text-decoration: none;
  }

  .breadcrumb-dark .breadcrumb-item a:hover {
    text-decoration: underline;
  }

  .breadcrumb-dark .breadcrumb-item.active {
    color: #ffffff;
  }

  .event-content {
    line-height: 1.8;
    font-size: 1.05rem;
    color: #333;
  }

  .event-content h2 {
    margin-top: 2rem;
    margin-bottom: 1rem;
    color: #1a1a1a;
    font-weight: bold;
    border-bottom: 3px solid #ffc107;
    padding-bottom: 0.5rem;
  }

  .event-content h3 {
    margin-top: 1.5rem;
    margin-bottom: 0.75rem;
    color: #333;
    font-weight: 600;
  }

  .event-content p {
    margin-bottom: 1rem;
  }

  .event-content ul {
    margin-bottom: 1rem;
    padding-left: 2rem;
  }

  .event-content ol {
    margin-bottom: 1rem;
    padding-left: 2rem;
  }

  .event-content li {
    margin-bottom: 0.5rem;
  }

  .event-content a {
    color: #ffc107;
    text-decoration: none;
  }

  .event-content a:hover {
    text-decoration: underline;
  }

  .event-content strong {
    color: #1a1a1a;
  }

  .event-details-card {
    border: 2px solid #ffc107 !important;
    border-radius: 8px;
    box-shadow: 0 4px 15px rgba(0, 0, 0, 0.1);
  }

  .event-details-card .card-title {
    color: #1a1a1a;
    font-size: 1.3rem;
    font-weight: bold;
  }

  .event-details-card .list-group-item {
    border-left: 4px solid #ffc107;
    padding: 1rem;
    font-size: 1rem;
  }

  .event-details-card .list-group-item strong {
    color: #1a1a1a;
  }

  .nav-section {
    background: linear-gradient(180deg, #f8f9fa 0%, #ffffff 100%);
    border-top: 3px solid #ffc107;
  }

  .back-btn {
    transition: all 0.3s ease;
    box-shadow: 0 2px 8px rgba(255, 193, 7, 0.2);
  }

  .back-btn:hover {
    transform: translateX(-5px);
    box-shadow: 0 4px 12px rgba(255, 193, 7, 0.4);
  }

  .hero-section {
    position: relative;
    overflow: hidden;
  }

  .hero-section::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background: linear-gradient(135deg, rgba(255, 193, 7, 0.1) 0%, rgba(0, 0, 0, 0.3) 100%);
    pointer-events: none;
  }

  .hero-section .display-4 {
    position: relative;
    z-index: 1;
  }

  .content-section {
    background: #ffffff;
  }

  .image-wrapper {
    overflow: hidden;
    border-radius: 12px;
  }

  .image-wrapper img {
    transition: transform 0.3s ease;
  }

  .image-wrapper:hover img {
    transform: scale(1.02);
  }
</style>
