---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Join Us" description="Join the BG Leos and become part of a community dedicated to leadership and service">
  <!-- Hero Section -->
  <section class="hero-join" style="margin-top: -76px; padding-top: 150px; background: linear-gradient(135deg, var(--secondary-color) 0%, #0f0f1e 100%); position: relative; overflow: hidden;">
    <div style="position: absolute; top: 0; left: 0; right: 0; bottom: 0; background: url('/images/hero-1.jpeg'); background-repeat: no-repeat; background-size: cover; opacity: 0.5; animation: float 6s ease-in-out infinite;"></div>
    
    <div class="container py-5 text-center text-white position-relative" style="z-index: 2;">
      <h1 class="display-3 fw-bold mb-4" style="font-size: 3.5rem; font-weight: 800; letter-spacing: -1px; background: linear-gradient(135deg, #fff350, #ffc107, #e0a800); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text; line-height: 1.2;">
        Join the BG Leos Family
      </h1>
      <p class="lead mb-0" style="font-size: 1.4rem; color: #cbd5e1; line-height: 1.8;">
        Be part of a community dedicated to leadership, experience, and opportunity
      </p>
    </div>
  </section>

  <!-- Why Join Section -->
  <section class="py-5" style="padding: 100px 0;">
    <div class="container py-5">
      <h2 class="section-title mb-5">Why Join BG Leos?</h2>
      
      <div class="row g-4">
        <!-- Benefit 1 -->
        <div class="col-lg-4 col-md-6">
          <div class="benefit-card" style="background: white; border-radius: 16px; padding: 40px 30px; box-shadow: 0 10px 30px rgba(0, 0, 0, 0.12); transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1); position: relative; overflow: hidden; height: 100%;">
            <div style="position: absolute; top: 0; left: 0; right: 0; height: 4px; background: linear-gradient(to right, #ffc107, #c41e3a); transform: scaleX(0); transition: transform 0.4s cubic-bezier(0.4, 0, 0.2, 1); transform-origin: left; z-index: 10;"></div>
            
            <div class="benefit-icon" style="width: 80px; height: 80px; background: linear-gradient(135deg, #ffc107, #ffb300); border-radius: 16px; display: flex; align-items: center; justify-content: center; margin-bottom: 25px; font-size: 2.2rem; color: white; box-shadow: 0 8px 25px rgba(255, 193, 7, 0.3);">
              <i class="fas fa-users"></i>
            </div>
            
            <h4 style="font-size: 1.3rem; font-weight: 800; color: #1a1a2e; margin-bottom: 15px; letter-spacing: -0.5px;">Build Friendships</h4>
            <p style="color: #6b7280; line-height: 1.7; font-size: 0.95rem;">Connect with like-minded individuals who share your passion for making a difference in the community.</p>
          </div>
        </div>

        <!-- Benefit 2 -->
        <div class="col-lg-4 col-md-6">
          <div class="benefit-card" style="background: white; border-radius: 16px; padding: 40px 30px; box-shadow: 0 10px 30px rgba(0, 0, 0, 0.12); transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1); position: relative; overflow: hidden; height: 100%;">
            <div style="position: absolute; top: 0; left: 0; right: 0; height: 4px; background: linear-gradient(to right, #ffc107, #c41e3a); transform: scaleX(0); transition: transform 0.4s cubic-bezier(0.4, 0, 0.2, 1); transform-origin: left; z-index: 10;"></div>
            
            <div class="benefit-icon" style="width: 80px; height: 80px; background: linear-gradient(135deg, #c41e3a, #a01830); border-radius: 16px; display: flex; align-items: center; justify-content: center; margin-bottom: 25px; font-size: 2.2rem; color: white; box-shadow: 0 8px 25px rgba(196, 30, 58, 0.3);">
              <i class="fas fa-star"></i>
            </div>
            
            <h4 style="font-size: 1.3rem; font-weight: 800; color: #1a1a2e; margin-bottom: 15px; letter-spacing: -0.5px;">Leadership Development</h4>
            <p style="color: #6b7280; line-height: 1.7; font-size: 0.95rem;">Develop essential leadership skills through hands-on experience with meaningful community projects.</p>
          </div>
        </div>

        <!-- Benefit 3 -->
        <div class="col-lg-4 col-md-6">
          <div class="benefit-card" style="background: white; border-radius: 16px; padding: 40px 30px; box-shadow: 0 10px 30px rgba(0, 0, 0, 0.12); transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1); position: relative; overflow: hidden; height: 100%;">
            <div style="position: absolute; top: 0; left: 0; right: 0; height: 4px; background: linear-gradient(to right, #ffc107, #c41e3a); transform: scaleX(0); transition: transform 0.4s cubic-bezier(0.4, 0, 0.2, 1); transform-origin: left; z-index: 10;"></div>
            
            <div class="benefit-icon" style="width: 80px; height: 80px; background: linear-gradient(135deg, #1a1a2e, #0f0f1e); border-radius: 16px; display: flex; align-items: center; justify-content: center; margin-bottom: 25px; font-size: 2.2rem; color: #ffc107; box-shadow: 0 8px 25px rgba(26, 26, 46, 0.3);">
              <i class="fas fa-heart"></i>
            </div>
            
            <h4 style="font-size: 1.3rem; font-weight: 800; color: #1a1a2e; margin-bottom: 15px; letter-spacing: -0.5px;">Make an Impact</h4>
            <p style="color: #6b7280; line-height: 1.7; font-size: 0.95rem;">Contribute to meaningful projects that create positive change in Baddegama and beyond.</p>
          </div>
        </div>

        <!-- Benefit 4 -->
        <div class="col-lg-4 col-md-6">
          <div class="benefit-card" style="background: white; border-radius: 16px; padding: 40px 30px; box-shadow: 0 10px 30px rgba(0, 0, 0, 0.12); transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1); position: relative; overflow: hidden; height: 100%;">
            <div style="position: absolute; top: 0; left: 0; right: 0; height: 4px; background: linear-gradient(to right, #ffc107, #c41e3a); transform: scaleX(0); transition: transform 0.4s cubic-bezier(0.4, 0, 0.2, 1); transform-origin: left; z-index: 10;"></div>
            
            <div class="benefit-icon" style="width: 80px; height: 80px; background: linear-gradient(135deg, #10b981, #059669); border-radius: 16px; display: flex; align-items: center; justify-content: center; margin-bottom: 25px; font-size: 2.2rem; color: white; box-shadow: 0 8px 25px rgba(16, 185, 129, 0.3);">
              <i class="fas fa-book"></i>
            </div>
            
            <h4 style="font-size: 1.3rem; font-weight: 800; color: #1a1a2e; margin-bottom: 15px; letter-spacing: -0.5px;">Lifelong Learning</h4>
            <p style="color: #6b7280; line-height: 1.7; font-size: 0.95rem;">Gain knowledge and experience through workshops, seminars, and collaborative learning opportunities.</p>
          </div>
        </div>

        <!-- Benefit 5 -->
        <div class="col-lg-4 col-md-6">
          <div class="benefit-card" style="background: white; border-radius: 16px; padding: 40px 30px; box-shadow: 0 10px 30px rgba(0, 0, 0, 0.12); transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1); position: relative; overflow: hidden; height: 100%;">
            <div style="position: absolute; top: 0; left: 0; right: 0; height: 4px; background: linear-gradient(to right, #ffc107, #c41e3a); transform: scaleX(0); transition: transform 0.4s cubic-bezier(0.4, 0, 0.2, 1); transform-origin: left; z-index: 10;"></div>
            
            <div class="benefit-icon" style="width: 80px; height: 80px; background: linear-gradient(135deg, #8b5cf6, #7c3aed); border-radius: 16px; display: flex; align-items: center; justify-content: center; margin-bottom: 25px; font-size: 2.2rem; color: white; box-shadow: 0 8px 25px rgba(139, 92, 246, 0.3);">
              <i class="fas fa-network-wired"></i>
            </div>
            
            <h4 style="font-size: 1.3rem; font-weight: 800; color: #1a1a2e; margin-bottom: 15px; letter-spacing: -0.5px;">Networking</h4>
            <p style="color: #6b7280; line-height: 1.7; font-size: 0.95rem;">Expand your network and connect with professionals, leaders, and influencers in the region.</p>
          </div>
        </div>

        <!-- Benefit 6 -->
        <div class="col-lg-4 col-md-6">
          <div class="benefit-card" style="background: white; border-radius: 16px; padding: 40px 30px; box-shadow: 0 10px 30px rgba(0, 0, 0, 0.12); transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1); position: relative; overflow: hidden; height: 100%;">
            <div style="position: absolute; top: 0; left: 0; right: 0; height: 4px; background: linear-gradient(to right, #ffc107, #c41e3a); transform: scaleX(0); transition: transform 0.4s cubic-bezier(0.4, 0, 0.2, 1); transform-origin: left; z-index: 10;"></div>
            
            <div class="benefit-icon" style="width: 80px; height: 80px; background: linear-gradient(135deg, #f59e0b, #d97706); border-radius: 16px; display: flex; align-items: center; justify-content: center; margin-bottom: 25px; font-size: 2.2rem; color: white; box-shadow: 0 8px 25px rgba(245, 158, 11, 0.3);">
              <i class="fas fa-rocket"></i>
            </div>
            
            <h4 style="font-size: 1.3rem; font-weight: 800; color: #1a1a2e; margin-bottom: 15px; letter-spacing: -0.5px;">Career Growth</h4>
            <p style="color: #6b7280; line-height: 1.7; font-size: 0.95rem;">Enhance your resume with valuable leadership experience and community service credentials.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Google Form Section -->
  <section class="py-5" style="padding: 100px 0; background: linear-gradient(135deg, #f8f9fa 0%, #f3f4f6 100%);">
    <div class="container py-5">
      <div style="text-align: center; margin-bottom: 60px;">
        <h2 class="section-title">Ready to Join?</h2>
        <p style="font-size: 1.1rem; color: #6b7280; max-width: 600px; margin: 20px auto 0;">
          Fill out the form below to express your interest in joining the BG Leos. We look forward to welcoming you to our community!
        </p>
      </div>

      <!-- Form Container -->
      <div class="form-wrapper" style="max-width: 900px; margin: 0 auto; background: white; border-radius: 20px; padding: 50px; box-shadow: 0 20px 60px rgba(0, 0, 0, 0.1); border: 1px solid rgba(255, 193, 7, 0.1);">
        <iframe 
          src="https://docs.google.com/forms/d/e/1FAIpQLScCOG0T86InNFJdL70RzK8NKgFhE7EJ3HK6gRwQ00KoPLFwEA/viewform?embedded=true" 
          width="100%" 
          height="800" 
          frameborder="0" 
          marginheight="0" 
          marginwidth="0"
          style="border-radius: 12px; border: none;"
        >
          Loading…
        </iframe>
      </div>
    </div>
  </section>

  <!-- CTA Section -->
  <!-- <section class="py-5" style="padding: 80px 0; background: linear-gradient(135deg, var(--secondary-color) 0%, #0f0f1e 100%); position: relative; overflow: hidden;">
    <div style="position: absolute; top: 0; left: 0; right: 0; height: 1px; background: linear-gradient(to right, transparent, rgba(255, 193, 7, 0.3), transparent);"></div>
    
    <div class="container py-5 text-center text-white position-relative" style="z-index: 2;">
      <h3 class="display-5 fw-bold mb-4" style="font-size: 2.5rem; font-weight: 800; letter-spacing: -0.5px;">Have Questions?</h3>
      <p class="lead mb-4" style="font-size: 1.1rem; color: #cbd5e1; margin-bottom: 30px;">
        Feel free to reach out to us for more information about membership and our activities.
      </p>
      <div style="display: flex; flex-wrap: wrap; gap: 20px; justify-content: center; align-items: center;">
        <a href="/contact" class="btn btn-warning" style="font-weight: 700; text-transform: uppercase; letter-spacing: 0.5px; padding: 14px 32px; font-size: 1rem; box-shadow: 0 8px 25px rgba(255, 193, 7, 0.4); transition: all 0.3s ease;">
          Contact Us
        </a>
        <a href="/events" class="btn btn-outline-light" style="font-weight: 700; text-transform: uppercase; letter-spacing: 0.5px; padding: 14px 32px; font-size: 1rem; border-width: 2px; transition: all 0.3s ease;">
          View Events
        </a>
      </div>
    </div>
  </section> -->

  <style>
    @keyframes float {
      0%, 100% {
        transform: translateY(0px);
      }
      50% {
        transform: translateY(-20px);
      }
    }

    .benefit-card:hover {
      transform: translateY(-16px);
      box-shadow: 0 20px 50px rgba(196, 30, 58, 0.2);
    }

    .benefit-card:hover > div:first-child {
      transform: scaleX(1);
    }

    .form-wrapper {
      border-top: 4px solid transparent;
      background: linear-gradient(white, white) padding-box,
                  linear-gradient(135deg, #ffc107, #c41e3a) border-box;
    }

    /* Responsive adjustments */
    @media (max-width: 768px) {
      .form-wrapper {
        padding: 30px 20px;
      }

      .benefit-icon {
        width: 60px;
        height: 60px;
        font-size: 1.8rem;
      }

      h2.section-title {
        font-size: 1.8rem;
      }
    }

    @media (max-width: 576px) {
      .form-wrapper {
        padding: 20px;
      }

      .form-wrapper iframe {
        height: 600px !important;
      }
    }
  </style>
</Layout>
