---
// Import global styles
import '../styles/global.css';
import { SEO } from 'astro-seo';

// Props
export interface Props {
  title: string;
  description?: string;
  image?: string;
  url?: string;
}

const { title, description = 'Leo Club of Baddegama - Making a difference through leadership and service', image, url } = Astro.props;
const siteUrl = 'https://bgleo.netlify.app';
const canonicalUrl = url || `${siteUrl}${Astro.url.pathname}`;
const normalizedImage = image
  ? (image.startsWith('http') ? image : `${siteUrl}${image}`)
  : `${siteUrl}/images/hero-1.jpeg`;
const pageTitle = title === 'Home' ? 'Leo Club of Baddegama | BG Leos' : `${title} | BG Leos`;
const pageDescription = description || 'BG Leos is the Leo Club of Baddegama, inspiring young leaders through community service, projects, and leadership development.';
const organizationSchema = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  name: 'BG Leos',
  url: siteUrl,
  logo: `${siteUrl}/images/logo.png`,
  description: pageDescription,
  sameAs: [
    'https://www.facebook.com/bgleos',
    'https://www.instagram.com/leosofbaddegama/',
    'https://www.youtube.com/@leo.club.of.baddegama',
    'https://whatsapp.com/channel/0029Vb7K1d8Fy72CMkQ9O13G'
  ],
  address: {
    '@type': 'PostalAddress',
    addressLocality: 'Baddegama',
    addressRegion: 'Galle',
    addressCountry: 'LK'
  },
  contactPoint: {
    '@type': 'ContactPoint',
    contactType: 'general inquiry',
    email: 'info@bgleos.org'
  }
};
---

<!DOCTYPE html>
<html lang="en">
